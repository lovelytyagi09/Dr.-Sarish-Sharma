<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SpineArticle 03 — Slipped Disc or Muscle Spasm?</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,500;0,600;0,700;1,400;1,600&family=Figtree:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
@import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,500;0,600;0,700;1,400;1,600&family=Figtree:wght@300;400;500;600&display=swap');
:root {
  --navy: #1A2744;
  --navy-d: #0F1A30;
  --teal: #1AAB98;
  --teal-d: #148A79;
  --gold: #C6993A;
  --white: #ffffff;
  --off-white: #F5F4EF;
  --gray-lt: #ECEDF2;
  --gray: #8A97AB;
  --gray-dk: #3F5264;
  --text: #171F2D;
  --text-lt: #4A5F75;
  --border: #DDE2EC;
  --font-head: 'Fraunces', Georgia, serif;
  --font-body: 'Figtree', sans-serif;
  --radius-sm: 6px;
  --radius: 14px;
  --radius-lg: 22px;
  --shadow-sm: 0 2px 8px rgba(15, 26, 48, 0.06);
  --shadow: 0 4px 24px rgba(15, 26, 48, 0.09);
  --shadow-lg: 0 12px 48px rgba(15, 26, 48, 0.13);
  --transition: 0.25s ease;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  background: var(--off-white);
  color: var(--text);
  line-height: 1.7;
  overflow-x: hidden;
}

/* ── TOPBAR ── */
.topbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 40px;
  height: 64px;
  background: rgba(10, 17, 34, 0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.topbar-brand {
  font-family: var(--font-head);
  font-size: 1rem; font-weight: 700;
  color: var(--white);
  letter-spacing: 0.02em;
}
.topbar-brand span { color: var(--teal); }
.topbar-meta {
  font-size: 0.75rem; font-weight: 500;
  color: var(--gray);
  letter-spacing: 0.1em; text-transform: uppercase;
}
.topbar-tag {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(26, 171, 152, 0.15);
  border: 1px solid rgba(26, 171, 152, 0.3);
  color: var(--teal);
  font-size: 0.7rem; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  padding: 4px 12px; border-radius: 20px;
}

/* ── HERO ── */
.hero {
  min-height: 100vh;
  background: var(--navy-d);
  display: grid;
  grid-template-columns: 1fr 480px;
  position: relative;
  overflow: hidden;
  padding-top: 64px;
}

.hero-noise {
  position: absolute; inset: 0; pointer-events: none; z-index: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  opacity: 0.6;
}

.hero-glow {
  position: absolute;
  width: 700px; height: 700px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(26,171,152,0.18) 0%, transparent 70%);
  top: -100px; right: 300px;
  pointer-events: none;
}

.hero-left {
  position: relative; z-index: 2;
  display: flex; flex-direction: column; justify-content: center;
  padding: 80px 60px 80px 80px;
}

.article-label {
  display: inline-flex; align-items: center; gap: 10px;
  margin-bottom: 32px;
}
.label-number {
  font-family: var(--font-head);
  font-size: 0.75rem; font-style: italic; font-weight: 400;
  color: var(--gold);
  border: 1px solid rgba(198,153,58,0.4);
  padding: 3px 10px; border-radius: 4px;
}
.label-cat {
  font-size: 0.7rem; font-weight: 600;
  letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--gray);
}
.label-line {
  width: 30px; height: 1px;
  background: var(--gray);
}

.hero-title {
  font-family: var(--font-head);
  font-size: clamp(2.4rem, 4.5vw, 3.6rem);
  font-weight: 700;
  line-height: 1.12;
  color: var(--white);
  margin-bottom: 28px;
}
.hero-title em {
  font-style: italic; font-weight: 600;
  color: var(--teal);
}

.hero-sub {
  font-size: 1.05rem; font-weight: 300;
  color: rgba(255,255,255,0.6);
  max-width: 520px;
  line-height: 1.75;
  margin-bottom: 48px;
}

.hero-meta-row {
  display: flex; align-items: center; gap: 24px;
  padding-top: 32px;
  border-top: 1px solid rgba(255,255,255,0.08);
}
.meta-avatar {
  width: 42px; height: 42px; border-radius: 50%;
  background: linear-gradient(135deg, var(--teal), var(--navy));
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-head); font-weight: 700; font-size: 0.85rem;
  color: var(--white); flex-shrink: 0;
}
.meta-info { flex: 1; }
.meta-name {
  font-size: 0.85rem; font-weight: 600;
  color: var(--white); margin-bottom: 2px;
}
.meta-role {
  font-size: 0.75rem; font-weight: 400;
  color: var(--gray);
}
.meta-divider { width: 1px; height: 32px; background: rgba(255,255,255,0.1); }
.meta-stat { text-align: center; }
.meta-stat-val {
  font-family: var(--font-head);
  font-size: 1.1rem; font-weight: 700;
  color: var(--white); display: block;
}
.meta-stat-lbl {
  font-size: 0.68rem; font-weight: 500;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--gray);
}

/* Hero right – anatomy panel */
.hero-right {
  position: relative; z-index: 2;
  display: flex; align-items: center; justify-content: center;
  padding: 80px 40px;
  border-left: 1px solid rgba(255,255,255,0.05);
}

.spine-panel {
  width: 100%; max-width: 340px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: var(--radius-lg);
  padding: 32px 28px;
  backdrop-filter: blur(8px);
}
.panel-title {
  font-size: 0.7rem; font-weight: 600;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--gray);
  margin-bottom: 24px;
  display: flex; align-items: center; gap: 8px;
}
.panel-title::after {
  content: ''; flex: 1; height: 1px;
  background: rgba(255,255,255,0.07);
}

.spine-svg-wrap {
  display: flex; justify-content: center;
  margin-bottom: 28px;
  position: relative;
}

/* Inline spine SVG */
.spine-diagram { width: 160px; }

.comparison-cards {
  display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
}
.ccard {
  border-radius: var(--radius);
  padding: 16px 14px;
  position: relative; overflow: hidden;
}
.ccard--disc {
  background: rgba(26,171,152,0.1);
  border: 1px solid rgba(26,171,152,0.2);
}
.ccard--spasm {
  background: rgba(198,153,58,0.1);
  border: 1px solid rgba(198,153,58,0.2);
}
.ccard-icon {
  font-size: 1.4rem; margin-bottom: 8px; display: block;
}
.ccard-name {
  font-size: 0.72rem; font-weight: 600;
  text-transform: uppercase; letter-spacing: 0.1em;
  margin-bottom: 6px;
}
.ccard--disc .ccard-name { color: var(--teal); }
.ccard--spasm .ccard-name { color: var(--gold); }
.ccard-desc {
  font-size: 0.73rem; font-weight: 300;
  color: rgba(255,255,255,0.5);
  line-height: 1.5;
}

/* ── PROGRESS INDICATOR ── */
.progress-bar {
  position: fixed; top: 64px; left: 0; right: 0;
  height: 2px; background: rgba(255,255,255,0.06); z-index: 99;
}
.progress-fill {
  height: 100%; width: 0%;
  background: linear-gradient(90deg, var(--teal), var(--gold));
  transition: width 0.1s linear;
}

/* ── ARTICLE BODY ── */
.article-body {
  max-width: 1140px;
  margin: 0 auto;
  padding: 80px 40px 120px;
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: 60px;
  align-items: start;
}

/* ── MAIN CONTENT ── */
.main-content { min-width: 0; }

.section { margin-bottom: 64px; }

.section-eyebrow {
  display: flex; align-items: center; gap: 12px;
  margin-bottom: 20px;
}
.eyebrow-num {
  font-family: var(--font-head);
  font-size: 0.7rem; font-style: italic;
  color: var(--teal);
  border: 1px solid rgba(26,171,152,0.35);
  padding: 2px 9px; border-radius: 4px;
}
.eyebrow-text {
  font-size: 0.68rem; font-weight: 600;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--gray);
}

.section-heading {
  font-family: var(--font-head);
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  font-weight: 700;
  color: var(--navy-d);
  line-height: 1.2;
  margin-bottom: 20px;
}
.section-heading em {
  font-style: italic; color: var(--teal);
}

.prose {
  font-size: 1rem; font-weight: 400;
  color: var(--text-lt);
  line-height: 1.85;
  margin-bottom: 20px;
}
.prose strong { color: var(--text); font-weight: 600; }

/* Comparison Table */
.compare-table {
  width: 100%; border-collapse: collapse;
  margin: 32px 0;
  border-radius: var(--radius); overflow: hidden;
  box-shadow: var(--shadow);
}
.compare-table thead tr {
  background: var(--navy);
}
.compare-table th {
  font-family: var(--font-body);
  font-size: 0.75rem; font-weight: 600;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: rgba(255,255,255,0.8);
  padding: 16px 20px;
  text-align: left;
}
.compare-table th:first-child { color: var(--gray); }
.compare-table td {
  padding: 14px 20px;
  font-size: 0.9rem;
  color: var(--text-lt);
  border-bottom: 1px solid var(--border);
  vertical-align: top;
}
.compare-table tbody tr:last-child td { border-bottom: none; }
.compare-table tbody tr:nth-child(even) td { background: var(--gray-lt); }
.compare-table tbody tr:nth-child(odd) td { background: var(--white); }
.compare-table td:first-child {
  font-weight: 600; color: var(--navy);
  background: var(--off-white) !important;
  white-space: nowrap;
}
.td-disc { color: var(--teal-d) !important; }
.td-spasm { color: #8A6010 !important; }

/* Symptom cards */
.symptom-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
  margin: 32px 0;
}
.sym-card {
  border-radius: var(--radius);
  padding: 24px;
  position: relative;
}
.sym-card--disc {
  background: linear-gradient(135deg, rgba(26,171,152,0.06) 0%, rgba(26,171,152,0.02) 100%);
  border: 1px solid rgba(26,171,152,0.2);
}
.sym-card--spasm {
  background: linear-gradient(135deg, rgba(198,153,58,0.07) 0%, rgba(198,153,58,0.02) 100%);
  border: 1px solid rgba(198,153,58,0.22);
}
.sym-card-header {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 16px;
}
.sym-dot {
  width: 10px; height: 10px; border-radius: 50%;
  flex-shrink: 0;
}
.sym-card--disc .sym-dot { background: var(--teal); }
.sym-card--spasm .sym-dot { background: var(--gold); }
.sym-card-title {
  font-family: var(--font-head);
  font-size: 1rem; font-weight: 700;
  color: var(--navy-d);
}
.sym-list {
  list-style: none; display: flex; flex-direction: column; gap: 9px;
}
.sym-list li {
  font-size: 0.88rem; color: var(--text-lt);
  display: flex; gap: 10px; align-items: flex-start;
  line-height: 1.5;
}
.sym-list li::before {
  content: '';
  width: 5px; height: 5px; border-radius: 50%;
  flex-shrink: 0; margin-top: 8px;
}
.sym-card--disc .sym-list li::before { background: var(--teal); }
.sym-card--spasm .sym-list li::before { background: var(--gold); }

/* Alert / call-out box */
.callout {
  border-radius: var(--radius);
  padding: 24px 28px;
  margin: 32px 0;
  display: flex; gap: 18px; align-items: flex-start;
}
.callout--warning {
  background: rgba(198,153,58,0.08);
  border-left: 4px solid var(--gold);
}
.callout--info {
  background: rgba(26,171,152,0.07);
  border-left: 4px solid var(--teal);
}
.callout--danger {
  background: rgba(220,50,50,0.06);
  border-left: 4px solid #DC3232;
}
.callout-icon { font-size: 1.4rem; flex-shrink: 0; line-height: 1; margin-top: 2px; }
.callout-body {}
.callout-title {
  font-family: var(--font-head);
  font-size: 1rem; font-weight: 700;
  color: var(--navy-d);
  margin-bottom: 6px;
}
.callout-text {
  font-size: 0.9rem; color: var(--text-lt);
  line-height: 1.7;
}
.callout-text strong { color: var(--text); }

/* Red flags */
.red-flag-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
  margin: 24px 0;
}
.rflag {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 18px 20px;
  display: flex; gap: 14px; align-items: flex-start;
  box-shadow: var(--shadow-sm);
  transition: box-shadow var(--transition), transform var(--transition);
}
.rflag:hover {
  box-shadow: var(--shadow);
  transform: translateY(-2px);
}
.rflag-icon {
  width: 36px; height: 36px; border-radius: 10px;
  background: rgba(220,50,50,0.08);
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem; flex-shrink: 0;
}
.rflag-text {
  font-size: 0.88rem; color: var(--text-lt);
  line-height: 1.55; font-weight: 400;
}
.rflag-text strong { color: var(--text); font-weight: 600; }

/* Step timeline */
.timeline {
  position: relative; margin: 32px 0;
  padding-left: 32px;
}
.timeline::before {
  content: '';
  position: absolute; left: 11px; top: 0; bottom: 0;
  width: 2px;
  background: linear-gradient(to bottom, var(--teal), var(--gold));
  border-radius: 2px;
}
.t-step {
  position: relative; margin-bottom: 32px;
}
.t-step:last-child { margin-bottom: 0; }
.t-dot {
  position: absolute; left: -28px; top: 4px;
  width: 16px; height: 16px; border-radius: 50%;
  background: var(--white);
  border: 3px solid var(--teal);
  box-shadow: 0 0 0 3px rgba(26,171,152,0.15);
}
.t-step:last-child .t-dot { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(198,153,58,0.15); }
.t-label {
  font-size: 0.7rem; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--teal); margin-bottom: 4px;
}
.t-step:last-child .t-label { color: var(--gold); }
.t-heading {
  font-family: var(--font-head);
  font-size: 1.05rem; font-weight: 700;
  color: var(--navy-d);
  margin-bottom: 8px;
}
.t-body {
  font-size: 0.9rem; color: var(--text-lt); line-height: 1.7;
}

/* Divider */
.section-divider {
  width: 60px; height: 3px;
  background: linear-gradient(90deg, var(--teal), var(--gold));
  border-radius: 2px;
  margin: 40px 0;
}

/* Pull quote */
.pullquote {
  position: relative;
  margin: 40px 0;
  padding: 28px 32px 28px 48px;
  border-radius: 0 var(--radius) var(--radius) 0;
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-d) 100%);
  border-left: 5px solid var(--teal);
}
.pullquote::before {
  content: '\201C';
  position: absolute; left: 14px; top: 10px;
  font-family: var(--font-head);
  font-size: 3.5rem; line-height: 1;
  color: var(--teal); opacity: 0.6;
}
.pullquote-text {
  font-family: var(--font-head);
  font-size: 1.15rem; font-style: italic;
  font-weight: 400; line-height: 1.65;
  color: var(--white);
  margin-bottom: 12px;
}
.pullquote-attr {
  font-size: 0.78rem; font-weight: 600;
  letter-spacing: 0.08em;
  color: var(--teal);
}

/* ── SIDEBAR ── */
.sidebar {
  position: sticky; top: 84px;
  display: flex; flex-direction: column; gap: 20px;
}
.sidebar-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 24px;
  box-shadow: var(--shadow-sm);
}
.sidebar-card-title {
  font-family: var(--font-head);
  font-size: 0.95rem; font-weight: 700;
  color: var(--navy-d);
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 8px;
}
.sidebar-card-title svg { color: var(--teal); }

/* TOC */
.toc-list {
  list-style: none;
  display: flex; flex-direction: column; gap: 2px;
}
.toc-list a {
  display: block;
  font-size: 0.82rem; font-weight: 400;
  color: var(--text-lt);
  text-decoration: none;
  padding: 7px 10px;
  border-radius: var(--radius-sm);
  transition: all var(--transition);
  line-height: 1.45;
}
.toc-list a:hover {
  background: var(--off-white);
  color: var(--teal);
  padding-left: 14px;
}
.toc-list a.active {
  background: rgba(26,171,152,0.08);
  color: var(--teal);
  font-weight: 600;
}

/* Specialist card */
.specialist-card {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-d) 100%);
  border: none;
}
.specialist-card .sidebar-card-title { color: var(--white); border-color: rgba(255,255,255,0.1); }
.spec-list {
  list-style: none;
  display: flex; flex-direction: column; gap: 10px;
}
.spec-list li {
  display: flex; align-items: center; gap: 10px;
  font-size: 0.83rem; color: rgba(255,255,255,0.65);
  line-height: 1.4;
}
.spec-badge {
  width: 28px; height: 28px; border-radius: 8px;
  background: rgba(26,171,152,0.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.85rem; flex-shrink: 0;
}

/* quick checklist */
.check-list {
  list-style: none;
  display: flex; flex-direction: column; gap: 8px;
}
.check-list li {
  display: flex; align-items: flex-start; gap: 10px;
  font-size: 0.82rem; color: var(--text-lt); line-height: 1.5;
}
.check-list li .ck {
  width: 18px; height: 18px; border-radius: 5px;
  background: rgba(26,171,152,0.12);
  border: 1.5px solid var(--teal);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-top: 1px;
  font-size: 0.7rem; color: var(--teal); font-weight: 700;
}

/* ── FOOTER ── */
.article-footer {
  background: var(--navy-d);
  padding: 64px 40px;
}
.footer-inner {
  max-width: 860px; margin: 0 auto; text-align: center;
}
.footer-disc-label {
  display: inline-block;
  font-size: 0.68rem; font-weight: 600;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--gray);
  border: 1px solid rgba(255,255,255,0.1);
  padding: 4px 12px; border-radius: 20px;
  margin-bottom: 16px;
}
.footer-disc {
  font-size: 0.83rem; color: rgba(255,255,255,0.35);
  line-height: 1.8; margin-bottom: 32px;
}
.footer-brand {
  font-family: var(--font-head);
  font-size: 1.4rem; font-weight: 700;
  color: var(--white);
}
.footer-brand span { color: var(--teal); }
.footer-tagline {
  font-size: 0.78rem; color: var(--gray);
  margin-top: 4px;
}

/* ── ANIMATIONS ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: translateY(0); }
}
.hero-left > * {
  animation: fadeUp 0.7s ease both;
}
.hero-left > *:nth-child(1) { animation-delay: 0.05s; }
.hero-left > *:nth-child(2) { animation-delay: 0.15s; }
.hero-left > *:nth-child(3) { animation-delay: 0.25s; }
.hero-left > *:nth-child(4) { animation-delay: 0.35s; }
.hero-right { animation: fadeUp 0.9s 0.3s ease both; }

/* Reveal on scroll */
.reveal {
  opacity: 0; transform: translateY(24px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.reveal.visible {
  opacity: 1; transform: none;
}

/* ── RESPONSIVE ── */
@media (max-width: 960px) {
  .hero { grid-template-columns: 1fr; min-height: auto; }
  .hero-right { display: none; }
