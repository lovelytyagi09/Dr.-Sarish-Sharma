  <style>
    @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,500;0,600;0,700;1,400;1,600&family=Figtree:wght@300;400;500;600&display=swap');

    :root {
      --navy: #1A2744;
      --navy-d: #0F1A30;
      --teal: #1AAB98;
      --teal-d: #148A79;
      --gold: #C6993A;
      --white: #ffffff;
      --off-white: #F5F4EF;
      --gray-lt: #ECEDF2;
      --gray: #8A97AB;
      --gray-dk: #3F5264;
      --text: #171F2D;
      --text-lt: #4A5F75;
      --border: #DDE2EC;
      --font-head: 'Fraunces', Georgia, serif;
      --font-body: 'Figtree', sans-serif;
      --radius-sm: 6px;
      --radius: 14px;
      --radius-lg: 22px;
      --shadow-sm: 0 2px 8px rgba(15,26,48,0.06);
      --shadow: 0 4px 24px rgba(15,26,48,0.09);
      --shadow-lg: 0 12px 48px rgba(15,26,48,0.13);
      --transition: 0.25s ease;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-body);
      background: var(--off-white);
      color: var(--text);
      line-height: 1.75;
      font-size: 1rem;
      -webkit-font-smoothing: antialiased;
    }

    /* ── PROGRESS BAR ── */
    #read-progress {
      position: fixed;
      top: 0; left: 0;
      height: 3px;
      width: 0%;
      background: linear-gradient(90deg, var(--teal), var(--gold));
      z-index: 1000;
      transition: width 0.1s linear;
    }

    /* ── HERO ── */
    .blog-hero {
      background: var(--navy-d);
      position: relative;
      overflow: hidden;
      padding: 100px 24px 80px;
    }

    .blog-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 80% at 80% 20%, rgba(26,171,152,0.13) 0%, transparent 60%),
        radial-gradient(ellipse 40% 60% at 10% 80%, rgba(198,153,58,0.08) 0%, transparent 55%);
      pointer-events: none;
    }

    /* Decorative bone/cross pattern */
    .hero-deco {
      position: absolute;
      top: 0; right: 0;
      width: 420px; height: 420px;
      opacity: 0.04;
      pointer-events: none;
    }

    .blog-hero-inner {
      max-width: 820px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    .article-series {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: rgba(26,171,152,0.12);
      border: 1px solid rgba(26,171,152,0.25);
      border-radius: 50px;
      padding: 6px 16px;
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--teal);
      margin-bottom: 28px;
    }

    .article-series .dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--teal);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.75); }
    }

    .blog-hero h1 {
      font-family: var(--font-head);
      font-size: clamp(2rem, 5vw, 3.4rem);
      font-weight: 700;
      color: var(--white);
      line-height: 1.2;
      margin-bottom: 24px;
    }

    .blog-hero h1 em {
      font-style: italic;
      color: var(--gold);
    }

    .hero-intro {
      font-size: 1.1rem;
      color: rgba(255,255,255,0.72);
      max-width: 680px;
      line-height: 1.8;
      margin-bottom: 36px;
      font-weight: 300;
    }

    .hero-meta {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 20px;
      padding-top: 28px;
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    .author-chip {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .author-avatar {
      width: 44px; height: 44px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--teal), var(--navy));
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-head);
      font-weight: 700;
      color: white;
      font-size: 1rem;
      border: 2px solid rgba(255,255,255,0.15);
    }

    .author-info .name {
      font-weight: 600;
      color: var(--white);
      font-size: 0.9rem;
    }

    .author-info .role {
      font-size: 0.75rem;
      color: var(--gray);
    }

    .meta-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-left: auto;
    }

    .meta-tag {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.55);
      padding: 4px 12px;
      border-radius: 50px;
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.04em;
    }

    .read-time {
      display: flex;
      align-items: center;
      gap: 6px;
      color: var(--gray);
      font-size: 0.8rem;
    }

    /* ── QUICK FACTS BANNER ── */
    .quick-facts {
      background: var(--navy);
      padding: 28px 24px;
    }

    .quick-facts-inner {
      max-width: 900px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 0;
    }

    .fact-item {
      text-align: center;
      padding: 12px 24px;
      border-right: 1px solid rgba(255,255,255,0.07);
    }

    .fact-item:last-child { border-right: none; }

    .fact-number {
      font-family: var(--font-head);
      font-size: 2rem;
      font-weight: 700;
      color: var(--teal);
      line-height: 1;
      margin-bottom: 4px;
    }

    .fact-label {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.5);
      line-height: 1.4;
    }

    /* ── LAYOUT ── */
    .blog-layout {
      max-width: 1100px;
      margin: 0 auto;
      padding: 64px 24px;
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 56px;
      align-items: start;
    }

    @media (max-width: 860px) {
      .blog-layout { grid-template-columns: 1fr; }
      .sidebar { order: -1; }
    }

    /* ── ARTICLE BODY ── */
    .article-body { min-width: 0; }

    /* Table of Contents */
    .toc-box {
      background: var(--white);
      border: 1px solid var(--border);
      border-left: 4px solid var(--teal);
      border-radius: var(--radius);
      padding: 28px 28px 24px;
      margin-bottom: 48px;
      box-shadow: var(--shadow-sm);
    }

    .toc-title {
      font-family: var(--font-head);
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--navy);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .toc-title svg { color: var(--teal); flex-shrink: 0; }

    .toc-list {
      list-style: none;
      counter-reset: toc;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .toc-list li { counter-increment: toc; }

    .toc-list a {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
      color: var(--text-lt);
      font-size: 0.88rem;
      font-weight: 500;
      transition: color var(--transition);
    }

    .toc-list a::before {
      content: counter(toc, decimal-leading-zero);
      font-family: var(--font-head);
      font-size: 0.75rem;
      color: var(--teal);
      font-weight: 700;
      min-width: 22px;
    }

    .toc-list a:hover { color: var(--teal); }

    /* Sections */
    .article-section { margin-bottom: 60px; }

    .section-tag {
      display: inline-block;
      background: rgba(26,171,152,0.08);
      color: var(--teal-d);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 4px 12px;
      border-radius: 50px;
      margin-bottom: 12px;
    }

    h2 {
      font-family: var(--font-head);
      font-size: clamp(1.5rem, 3vw, 2rem);
      font-weight: 700;
      color: var(--navy);
      line-height: 1.3;
      margin-bottom: 20px;
    }

    h2 em { font-style: italic; color: var(--teal); }

    h3 {
      font-family: var(--font-head);
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--navy);
      margin-top: 32px;
      margin-bottom: 14px;
    }

    p {
      color: var(--text-lt);
      font-size: 1rem;
      line-height: 1.85;
      margin-bottom: 18px;
    }

    strong { color: var(--text); font-weight: 600; }

    /* Pull Quote */
    .pull-quote {
      margin: 40px 0;
      padding: 32px 36px;
      background: var(--navy);
      border-radius: var(--radius-lg);
      position: relative;
      overflow: hidden;
    }

    .pull-quote::before {
      content: '"';
      position: absolute;
      top: -10px; left: 20px;
      font-family: var(--font-head);
      font-size: 8rem;
      color: rgba(26,171,152,0.1);
      line-height: 1;
      pointer-events: none;
    }

    .pull-quote p {
      font-family: var(--font-head);
      font-size: 1.25rem;
      font-style: italic;
      color: var(--white);
      line-height: 1.65;
      margin: 0;
      position: relative;
      z-index: 1;
    }

    .pull-quote cite {
      display: block;
      margin-top: 16px;
      font-family: var(--font-body);
      font-style: normal;
      font-size: 0.8rem;
      color: var(--teal);
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      position: relative;
      z-index: 1;
    }

    /* Info Cards */
    .info-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 32px;
      margin: 32px 0;
      box-shadow: var(--shadow-sm);
    }

    .info-card.teal { border-top: 4px solid var(--teal); }
    .info-card.gold { border-top: 4px solid var(--gold); }
    .info-card.navy { border-top: 4px solid var(--navy); }

    .info-card-title {
      font-family: var(--font-head);
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .info-card-icon {
      width: 32px; height: 32px;
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem;
      flex-shrink: 0;
    }

    .icon-teal { background: rgba(26,171,152,0.12); }
    .icon-gold { background: rgba(198,153,58,0.12); }
    .icon-navy { background: rgba(26,39,68,0.08); }

    /* Symptom List */
    .symptom-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 14px;
      margin: 24px 0;
    }

    .symptom-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      background: var(--off-white);
      border-radius: var(--radius);
      padding: 14px 16px;
    }

    .symptom-icon {
      width: 28px; height: 28px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.8rem;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .si-red { background: rgba(220,38,38,0.1); color: #dc2626; }
    .si-teal { background: rgba(26,171,152,0.1); color: var(--teal-d); }

    .symptom-text {
      font-size: 0.88rem;
      color: var(--text-lt);
      line-height: 1.5;
      font-weight: 500;
    }

    /* Comparison Table */
    .compare-table {
      width: 100%;
      border-collapse: collapse;
      margin: 28px 0;
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      font-size: 0.9rem;
    }

    .compare-table thead { background: var(--navy); }

    .compare-table thead th {
      padding: 14px 20px;
      text-align: left;
      color: rgba(255,255,255,0.85);
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 0.8rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .compare-table thead th:first-child { color: var(--teal); }

    .compare-table tbody tr:nth-child(even) { background: var(--off-white); }
    .compare-table tbody tr:nth-child(odd) { background: var(--white); }

    .compare-table td {
      padding: 13px 20px;
      color: var(--text-lt);
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }

    .compare-table td:first-child {
      font-weight: 600;
      color: var(--navy);
      white-space: nowrap;
    }

    /* Process Steps */
    .steps-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 18px;
      margin: 24px 0;
    }

    .step-item {
      display: flex;
      align-items: flex-start;
      gap: 18px;
      background: var(--white);
      border-radius: var(--radius);
      padding: 20px 22px;
      border: 1px solid var(--border);
      box-shadow: var(--shadow-sm);
    }

    .step-num {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: var(--navy);
      color: white;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-head);
      font-weight: 700;
      font-size: 0.9rem;
      flex-shrink: 0;
    }

    .step-content .step-title {
      font-weight: 600;
      color: var(--navy);
      font-size: 0.95rem;
      margin-bottom: 4px;
    }

    .step-content p {
      font-size: 0.88rem;
      margin: 0;
    }

    /* Warning Box */
    .warning-box {
      background: rgba(198,153,58,0.07);
      border: 1px solid rgba(198,153,58,0.3);
      border-left: 4px solid var(--gold);
      border-radius: var(--radius);
      padding: 20px 24px;
      margin: 28px 0;
      display: flex;
      gap: 14px;
      align-items: flex-start;
    }

    .warning-icon {
      font-size: 1.3rem;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .warning-box p {
      font-size: 0.9rem;
      margin: 0;
      color: var(--gray-dk);
    }

    .warning-box strong { color: var(--navy); }

    /* Nutrient visual cards */
    .nutrient-cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin: 32px 0;
    }

    @media (max-width: 600px) {
      .nutrient-cards { grid-template-columns: 1fr; }
    }

    .nutrient-card {
      border-radius: var(--radius-lg);
      padding: 28px 24px;
      position: relative;
      overflow: hidden;
    }

    .nc-teal {
      background: linear-gradient(135deg, var(--teal-d), #0d7a6e);
      color: white;
    }

    .nc-navy {
      background: linear-gradient(135deg, var(--navy), var(--navy-d));
      color: white;
    }

    .nc-emoji {
      font-size: 2.5rem;
      margin-bottom: 12px;
      display: block;
    }

    .nc-name {
      font-family: var(--font-head);
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 4px;
    }

    .nc-subtitle {
      font-size: 0.75rem;
      opacity: 0.7;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 18px;
    }

    .nc-roles {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .nc-roles li {
      font-size: 0.82rem;
      opacity: 0.85;
      display: flex;
      align-items: flex-start;
      gap: 8px;
      line-height: 1.4;
    }

    .nc-roles li::before {
      content: '→';
      opacity: 0.6;
      flex-shrink: 0;
    }

    /* CTA Section */
    .cta-block {
      background: linear-gradient(135deg, var(--navy), var(--navy-d));
      border-radius: var(--radius-lg);
      padding: 48px 40px;
      text-align: center;
      margin: 60px 0 0;
      position: relative;
      overflow: hidden;
    }

    .cta-block::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 60% 60% at 50% 0%, rgba(26,171,152,0.15) 0%, transparent 70%);
      pointer-events: none;
    }

    .cta-block h3 {
      font-family: var(--font-head);
      font-size: 1.7rem;
      color: var(--white);
      margin-bottom: 12px;
      position: relative;
    }

    .cta-block p {
      color: rgba(255,255,255,0.65);
      max-width: 480px;
      margin: 0 auto 28px;
      font-size: 0.95rem;
      position: relative;
    }

    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--teal);
      color: white;
      text-decoration: none;
      padding: 14px 32px;
      border-radius: 50px;
      font-weight: 600;
      font-size: 0.95rem;
      transition: background var(--transition), transform var(--transition), box-shadow var(--transition);
      box-shadow: 0 4px 20px rgba(26,171,152,0.35);
      position: relative;
    }

    .cta-btn:hover {
      background: var(--teal-d);
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(26,171,152,0.45);
    }

    /* ── SIDEBAR ── */
    .sidebar { display: flex; flex-direction: column; gap: 28px; }

    .sidebar-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 28px 24px;
      box-shadow: var(--shadow-sm);
    }

    .sidebar-card-title {
      font-family: var(--font-head);
      font-size: 1rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 18px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
    }

    /* Doctor card */
