          </div>
        </div>

        <h3>Vitamin B12 Deficiency Symptoms</h3>
        <div class="symptom-grid">
          <div class="symptom-item">
            <div class="symptom-icon si-teal">↯</div>
            <div class="symptom-text">Tingling, numbness, or burning sensation in hands and feet</div>
          </div>
