<script>
// Progress bar
const pFill = document.getElementById('pFill');
window.addEventListener('scroll', () => {
  const h = document.documentElement;
  pFill.style.width = (h.scrollTop / (h.scrollHeight - h.clientHeight) * 100) + '%';
});

// Scroll reveal
const revEls = document.querySelectorAll('.reveal');
const revObs = new IntersectionObserver(es => {
  es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); revObs.unobserve(e.target); } });
}, { threshold: 0.08 });
revEls.forEach(el => revObs.observe(el));

// Animate outcome bars
const bars = document.querySelectorAll('.ob-fill');
const barObs = new IntersectionObserver(es => {
  es.forEach(e => {
    if (e.isIntersecting) {
      e.target.style.width = e.target.dataset.w + '%';
      barObs.unobserve(e.target);
    }
  });
}, { threshold: 0.3 });
bars.forEach(b => { b.style.width = '0%'; barObs.observe(b); });

// Active TOC
const secs = document.querySelectorAll('section[id]');
const tocAs = document.querySelectorAll('.toc-list a');
const tocObs = new IntersectionObserver(es => {
  es.forEach(e => {
    if (e.isIntersecting) {
      tocAs.forEach(a => a.classList.remove('active'));
      const a = document.querySelector(`.toc-list a[href="#${e.target.id}"]`);
      if (a) a.classList.add('active');
    }
  });
}, { rootMargin: '-20% 0px -70% 0px' });
secs.forEach(s => tocObs.observe(s));

// Bone diagram switcher
const svgs = {
  normal: {
    svg: `<svg viewBox="0 0 200 220" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:180px">
      <!-- Tibia shaft upper -->
      <rect x="72" y="10" width="56" height="80" rx="14" fill="#1A2744" stroke="#3F5264" stroke-width="1.5"/>
      <!-- callus bridge (green = good) -->
      <ellipse cx="100" cy="100" rx="38" ry="14" fill="rgba(26,171,152,0.25)" stroke="#1AAB98" stroke-width="1.8" stroke-dasharray="0"/>
      <text x="100" y="104" text-anchor="middle" font-family="Figtree" font-size="8" fill="#1AAB98" font-weight="600">Callus bridge</text>
      <!-- fracture line (healed) -->
      <line x1="72" y1="95" x2="128" y2="95" stroke="rgba(26,171,152,0.4)" stroke-width="1" stroke-dasharray="3,3"/>
      <!-- Tibia shaft lower -->
      <rect x="72" y="115" width="56" height="80" rx="14" fill="#1A2744" stroke="#3F5264" stroke-width="1.5"/>
      <!-- union indicator -->
      <circle cx="156" cy="100" r="14" fill="rgba(26,171,152,0.15)" stroke="#1AAB98" stroke-width="1.5"/>
      <text x="156" y="96" text-anchor="middle" font-family="Figtree" font-size="7" fill="#1AAB98" font-weight="700">✓</text>
      <text x="156" y="107" text-anchor="middle" font-family="Figtree" font-size="6" fill="rgba(26,171,152,0.7)">Union</text>
      <line x1="128" y1="100" x2="142" y2="100" stroke="rgba(26,171,152,0.3)" stroke-width="1"/>
    </svg>`,
    title: 'Normal Fracture Healing',
    text: 'Callus bridges the fracture gap by 4–6 weeks. Three cortices bridged by 12 weeks indicates clinical union. Remodelling continues for months.'
  },
  delayed: {
    svg: `<svg viewBox="0 0 200 220" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:180px">
      <!-- Tibia shaft upper -->
      <rect x="72" y="10" width="56" height="78" rx="14" fill="#1A2744" stroke="#3F5264" stroke-width="1.5"/>
      <!-- sparse callus -->
      <ellipse cx="94" cy="97" rx="14" ry="7" fill="rgba(198,153,58,0.2)" stroke="rgba(198,153,58,0.5)" stroke-width="1.2"/>
      <ellipse cx="112" cy="99" rx="10" ry="5" fill="rgba(198,153,58,0.15)" stroke="rgba(198,153,58,0.3)" stroke-width="1"/>
      <!-- gap -->
      <line x1="72" y1="93" x2="128" y2="93" stroke="rgba(198,153,58,0.6)" stroke-width="2" stroke-dasharray="4,3"/>
      <text x="100" y="89" text-anchor="middle" font-family="Figtree" font-size="7" fill="#C6993A" font-weight="600">Incomplete callus</text>
      <!-- Tibia shaft lower -->
      <rect x="72" y="108" width="56" height="80" rx="14" fill="#1A2744" stroke="#3F5264" stroke-width="1.5"/>
      <!-- warning indicator -->
      <circle cx="156" cy="100" r="14" fill="rgba(198,153,58,0.15)" stroke="#C6993A" stroke-width="1.5"/>
      <text x="156" y="97" text-anchor="middle" font-family="Figtree" font-size="8" fill="#C6993A" font-weight="700">⏳</text>
      <text x="156" y="109" text-anchor="middle" font-family="Figtree" font-size="5.5" fill="rgba(198,153,58,0.7)">Delayed</text>
      <line x1="128" y1="100" x2="142" y2="100" stroke="rgba(198,153,58,0.3)" stroke-width="1"/>
    </svg>`,
    title: 'Delayed Union',
    text: 'Sparse, incomplete callus visible after 3+ months. Fracture line still evident. Healing is occurring but too slowly — biological augmentation or optimisation needed.'
  },
  nonunion: {
    svg: `<svg viewBox="0 0 200 220" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:180px">
      <!-- Tibia shaft upper — sclerotic end -->
      <rect x="72" y="10" width="56" height="74" rx="14" fill="#1A2744" stroke="#3F5264" stroke-width="1.5"/>
      <rect x="76" y="74" width="48" height="8" rx="3" fill="#3F5264" opacity="0.7"/>
      <!-- Gap (no callus) -->
      <rect x="76" y="84" width="48" height="14" rx="2" fill="rgba(220,80,50,0.08)" stroke="rgba(220,80,50,0.35)" stroke-width="1.2" stroke-dasharray="4,3"/>
      <text x="100" y="94" text-anchor="middle" font-family="Figtree" font-size="7" fill="#DC5032" font-weight="600">No callus — gap</text>
      <!-- Sclerotic lower end -->
      <rect x="76" y="100" width="48" height="8" rx="3" fill="#3F5264" opacity="0.7"/>
      <!-- Tibia shaft lower -->
      <rect x="72" y="106" width="56" height="80" rx="14" fill="#1A2744" stroke="#3F5264" stroke-width="1.5"/>
      <!-- danger indicator -->
      <circle cx="156" cy="100" r="14" fill="rgba(220,80,50,0.12)" stroke="#DC5032" stroke-width="1.5"/>
      <text x="156" y="97" text-anchor="middle" font-family="Figtree" font-size="8" fill="#DC5032" font-weight="700">⛔</text>
      <text x="156" y="108" text-anchor="middle" font-family="Figtree" font-size="5" fill="rgba(220,80,50,0.7)">Non-union</text>
      <line x1="128" y1="100" x2="142" y2="100" stroke="rgba(220,80,50,0.3)" stroke-width="1"/>
      <!-- sclerosis labels -->
      <line x1="72" y1="78" x2="52" y2="70" stroke="rgba(255,255,255,0.15)" stroke-width="1" stroke-dasharray="2,3"/>
      <text x="10" y="70" font-family="Figtree" font-size="6.5" fill="rgba(255,255,255,0.35)">Sclerotic</text>
      <text x="12" y="79" font-family="Figtree" font-size="6.5" fill="rgba(255,255,255,0.35)">end plates</text>
    </svg>`,
    title: 'Non-Union',
    text: 'No callus formation. Sclerotic bone ends have sealed, blocking vascular ingrowth. Requires active biological intervention — BMI therapy or surgical bone graft.'
  }
};

function switchStage(type, el) {
  document.querySelectorAll('.stage-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  const wrap = document.getElementById('boneSvgWrap');
  const info = document.getElementById('boneInfoBox');
  wrap.innerHTML = svgs[type].svg;
  info.querySelector('.bib-title').textContent = svgs[type].title;
  info.querySelector('.bib-text').textContent = svgs[type].text;
}

// Init bone SVG
document.getElementById('boneSvgWrap').innerHTML = svgs.normal.svg;
</script>
