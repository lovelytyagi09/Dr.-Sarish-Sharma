<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Why Some Fractures Don't Heal — Bone Marrow Injection Therapy</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,500;0,600;0,700;1,400;1,600&family=Figtree:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #1A2744;
  --navy-d: #0F1A30;
  --teal: #1AAB98;
  --teal-d: #148A79;
  --gold: #C6993A;
  --white: #ffffff;
  --off-white: #F5F4EF;
  --gray-lt: #ECEDF2;
  --gray: #8A97AB;
  --gray-dk: #3F5264;
  --text: #171F2D;
  --text-lt: #4A5F75;
  --border: #DDE2EC;
  --font-head: 'Fraunces', Georgia, serif;
  --font-body: 'Figtree', sans-serif;
  --radius-sm: 6px;
  --radius: 14px;
  --radius-lg: 22px;
  --shadow-sm: 0 2px 8px rgba(15,26,48,0.06);
  --shadow: 0 4px 24px rgba(15,26,48,0.09);
  --shadow-lg: 0 12px 48px rgba(15,26,48,0.13);
  --transition: 0.25s ease;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--font-body);background:var(--off-white);color:var(--text);line-height:1.7;overflow-x:hidden}

/* ── TOPBAR ── */
.topbar{position:fixed;top:0;left:0;right:0;z-index:200;height:62px;display:flex;align-items:center;justify-content:space-between;padding:0 52px;background:rgba(9,15,30,0.95);backdrop-filter:blur(18px);border-bottom:1px solid rgba(255,255,255,0.045)}
.topbar-left{display:flex;align-items:center;gap:20px}
.topbar-brand{font-family:var(--font-head);font-size:1rem;font-weight:700;color:var(--white);letter-spacing:0.02em}
.topbar-brand span{color:var(--teal)}
.topbar-sep{width:1px;height:22px;background:rgba(255,255,255,0.1)}
.topbar-crumb{font-size:0.72rem;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;color:var(--gray)}
.topbar-right{display:flex;gap:8px;align-items:center}
.tb-pill{font-size:0.66rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:4px 12px;border-radius:20px}
.tb-teal{background:rgba(26,171,152,0.13);border:1px solid rgba(26,171,152,0.28);color:var(--teal)}
.tb-gold{background:rgba(198,153,58,0.13);border:1px solid rgba(198,153,58,0.28);color:var(--gold)}

/* ── PROGRESS ── */
.progress-bar{position:fixed;top:62px;left:0;right:0;height:2px;background:rgba(255,255,255,0.05);z-index:199}
.progress-fill{height:100%;width:0%;background:linear-gradient(90deg,var(--teal) 0%,var(--gold) 100%);transition:width 0.08s linear}

/* ── HERO ── */
.hero{min-height:100vh;background:var(--navy-d);position:relative;overflow:hidden;display:grid;grid-template-columns:1fr 420px;padding-top:62px}

/* animated scanline bg */
.hero-scanlines{position:absolute;inset:0;pointer-events:none;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(255,255,255,0.008) 3px,rgba(255,255,255,0.008) 4px);z-index:0}

/* radial light source */
.hero-light{position:absolute;top:-200px;left:-200px;width:900px;height:900px;border-radius:50%;background:radial-gradient(circle at 30% 30%,rgba(26,171,152,0.16) 0%,rgba(26,171,152,0.04) 40%,transparent 70%);pointer-events:none;z-index:0;animation:lightPulse 8s ease-in-out infinite}
@keyframes lightPulse{0%,100%{opacity:0.8;transform:scale(1)}50%{opacity:1;transform:scale(1.06)}}

.hero-light-2{position:absolute;bottom:-100px;right:300px;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(198,153,58,0.1) 0%,transparent 70%);pointer-events:none;z-index:0}

/* grid lines */
.hero-grid{position:absolute;inset:0;pointer-events:none;z-index:0;background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);background-size:64px 64px}

/* Left content */
.hero-left{position:relative;z-index:2;display:flex;flex-direction:column;justify-content:center;padding:80px 56px 80px 72px}

.hero-badge-row{display:flex;align-items:center;gap:12px;margin-bottom:32px}
.hbadge{font-family:var(--font-head);font-style:italic;font-size:0.72rem;font-weight:400;color:var(--gold);border:1px solid rgba(198,153,58,0.35);padding:3px 11px;border-radius:4px}
.hrule{width:36px;height:1px;background:rgba(255,255,255,0.12)}
.hcat{font-size:0.66rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:var(--gray)}

.hero-overtitle{font-size:0.8rem;font-weight:500;letter-spacing:0.05em;text-transform:uppercase;color:var(--teal);margin-bottom:16px}

.hero-title{font-family:var(--font-head);font-size:clamp(2rem,4.2vw,3.4rem);font-weight:700;line-height:1.1;color:var(--white);margin-bottom:26px}
.hero-title .ht-q{font-style:italic;color:rgba(255,255,255,0.9)}
.hero-title .ht-teal{color:var(--teal);font-style:italic}
.hero-title .ht-gold{color:var(--gold)}

.hero-sub{font-size:1rem;font-weight:300;color:rgba(255,255,255,0.55);line-height:1.85;max-width:540px;margin-bottom:44px}

/* stat trio */
.hero-stats{display:flex;gap:0;margin-bottom:44px;border-radius:var(--radius);overflow:hidden;border:1px solid rgba(255,255,255,0.07)}
.hstat{flex:1;padding:18px 20px;border-right:1px solid rgba(255,255,255,0.07);background:rgba(255,255,255,0.02)}
.hstat:last-child{border-right:none}
.hstat-val{font-family:var(--font-head);font-size:1.7rem;font-weight:700;color:var(--white);line-height:1;margin-bottom:4px}
.hstat-val span{font-size:0.9rem;font-style:italic;color:var(--teal)}
.hstat-label{font-size:0.66rem;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:var(--gray)}

/* author */
.hero-author{display:flex;align-items:center;gap:16px;padding-top:28px;border-top:1px solid rgba(255,255,255,0.07)}
.ha-avatar{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--teal-d),var(--navy));border:2px solid rgba(26,171,152,0.4);display:flex;align-items:center;justify-content:center;font-family:var(--font-head);font-size:0.88rem;font-weight:700;color:var(--white);flex-shrink:0}
.ha-name{font-size:0.86rem;font-weight:600;color:var(--white);margin-bottom:2px}
.ha-role{font-size:0.72rem;color:var(--gray)}
.ha-meta{margin-left:auto;text-align:right}
.ha-read{font-size:0.72rem;color:var(--gray)}
.ha-time{font-family:var(--font-head);font-size:1rem;font-weight:700;color:var(--white)}

/* Right panel — bone diagram */
.hero-right{position:relative;z-index:2;display:flex;align-items:center;justify-content:center;padding:60px 32px;border-left:1px solid rgba(255,255,255,0.04)}

.bone-panel{width:100%;max-width:320px}
.bp-label{font-size:0.66rem;font-weight:600;letter-spacing:0.13em;text-transform:uppercase;color:var(--gray);margin-bottom:20px;display:flex;align-items:center;gap:8px}
.bp-label::after{content:'';flex:1;height:1px;background:rgba(255,255,255,0.07)}

/* Healing stage tabs */
.stage-tabs{display:flex;gap:6px;margin-bottom:20px}
.stage-tab{flex:1;padding:7px 8px;border-radius:6px;font-size:0.65rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;text-align:center;cursor:pointer;transition:all var(--transition);border:1px solid rgba(255,255,255,0.08);color:rgba(255,255,255,0.35);background:transparent}
.stage-tab.active{background:rgba(26,171,152,0.18);border-color:rgba(26,171,152,0.4);color:var(--teal)}
.stage-tab.problem{background:rgba(220,80,50,0.12);border-color:rgba(220,80,50,0.3);color:#E07055}
.stage-tab.problem.active{background:rgba(220,80,50,0.22)}

.bone-svg-wrap{display:flex;justify-content:center;margin-bottom:20px;min-height:220px;align-items:center}

.bone-info-box{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:var(--radius);padding:14px 16px}
.bib-title{font-family:var(--font-head);font-size:0.88rem;font-weight:700;color:var(--white);margin-bottom:5px}
.bib-text{font-size:0.78rem;color:rgba(255,255,255,0.45);line-height:1.6}

/* ── ARTICLE BODY ── */
.article-body{max-width:1200px;margin:0 auto;padding:80px 52px 120px;display:grid;grid-template-columns:1fr 300px;gap:68px;align-items:start}
.main-content{min-width:0}
.section{margin-bottom:72px}

.sec-eyebrow{display:flex;align-items:center;gap:12px;margin-bottom:18px}
.sec-num{font-family:var(--font-head);font-style:italic;font-size:0.7rem;color:var(--teal);border:1px solid rgba(26,171,152,0.3);padding:2px 9px;border-radius:4px}
.sec-cat{font-size:0.66rem;font-weight:600;letter-spacing:0.13em;text-transform:uppercase;color:var(--gray)}

.sec-heading{font-family:var(--font-head);font-size:clamp(1.5rem,2.8vw,2.1rem);font-weight:700;color:var(--navy-d);line-height:1.2;margin-bottom:18px}
.sec-heading em{font-style:italic;color:var(--teal)}
.sec-heading .gold{color:var(--gold)}

.prose{font-size:0.97rem;color:var(--text-lt);line-height:1.9;margin-bottom:18px}
.prose strong{color:var(--text);font-weight:600}

.section-rule{width:52px;height:3px;background:linear-gradient(90deg,var(--teal),var(--gold));border-radius:2px;margin:52px 0}

/* ── FRACTURE TYPE CARDS ── */
.fracture-cards{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin:28px 0}
.fcard{border-radius:var(--radius);padding:22px 18px;position:relative;overflow:hidden;transition:transform var(--transition),box-shadow var(--transition)}
.fcard:hover{transform:translateY(-3px);box-shadow:var(--shadow)}
.fcard::after{content:'';position:absolute;inset:0;border-radius:var(--radius);pointer-events:none}
.fcard-normal{background:linear-gradient(145deg,rgba(26,171,152,0.08),rgba(26,171,152,0.02));border:1px solid rgba(26,171,152,0.2)}
.fcard-delayed{background:linear-gradient(145deg,rgba(198,153,58,0.08),rgba(198,153,58,0.02));border:1px solid rgba(198,153,58,0.22)}
.fcard-nonunion{background:linear-gradient(145deg,rgba(220,80,50,0.07),rgba(220,80,50,0.01));border:1px solid rgba(220,80,50,0.2)}
.fcard-icon{font-size:1.8rem;margin-bottom:10px;display:block}
.fcard-type{font-size:0.62rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:6px}
.fcard-normal .fcard-type{color:var(--teal)}
.fcard-delayed .fcard-type{color:var(--gold)}
.fcard-nonunion .fcard-type{color:#DC5032}
.fcard-name{font-family:var(--font-head);font-size:1rem;font-weight:700;color:var(--navy-d);margin-bottom:8px}
.fcard-timeline{font-size:0.75rem;font-weight:600;padding:3px 8px;border-radius:4px;display:inline-block;margin-bottom:10px}
.fcard-normal .fcard-timeline{background:rgba(26,171,152,0.1);color:var(--teal-d)}
.fcard-delayed .fcard-timeline{background:rgba(198,153,58,0.1);color:#8A6010}
.fcard-nonunion .fcard-timeline{background:rgba(220,80,50,0.1);color:#B53020}
.fcard-desc{font-size:0.81rem;color:var(--text-lt);line-height:1.6}

/* ── CAUSE GRID ── */
.cause-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:28px 0}
.cause-item{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:20px 18px;display:grid;grid-template-columns:36px 1fr;gap:12px;align-items:start;box-shadow:var(--shadow-sm);transition:all var(--transition)}
.cause-item:hover{box-shadow:var(--shadow);transform:translateY(-2px)}
.cause-icon-wrap{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
.ci-teal{background:rgba(26,171,152,0.1)}
.ci-gold{background:rgba(198,153,58,0.1)}
.ci-red{background:rgba(220,80,50,0.08)}
.ci-navy{background:rgba(26,39,68,0.08)}
.cause-title{font-family:var(--font-head);font-size:0.9rem;font-weight:700;color:var(--navy-d);margin-bottom:4px}
.cause-desc{font-size:0.8rem;color:var(--text-lt);line-height:1.55}

/* ── BMI PROCESS STEPS ── */
.process-flow{display:grid;grid-template-columns:repeat(4,1fr);gap:0;margin:32px 0;position:relative}
.process-flow::before{content:'';position:absolute;top:28px;left:10%;right:10%;height:2px;background:linear-gradient(90deg,var(--teal),var(--gold));z-index:0}
.pstep{position:relative;z-index:1;text-align:center;padding:0 8px}
.pstep-circle{width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;font-size:1.3rem;border:2px solid transparent;transition:all var(--transition)}
.pstep-1 .pstep-circle{background:rgba(26,171,152,0.12);border-color:rgba(26,171,152,0.4)}
.pstep-2 .pstep-circle{background:rgba(26,171,152,0.18);border-color:rgba(26,171,152,0.5)}
.pstep-3 .pstep-circle{background:rgba(198,153,58,0.12);border-color:rgba(198,153,58,0.4)}
.pstep-4 .pstep-circle{background:rgba(198,153,58,0.2);border-color:rgba(198,153,58,0.55)}
.pstep-num{font-family:var(--font-head);font-size:0.6rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--teal);margin-bottom:4px}
.pstep-3 .pstep-num,.pstep-4 .pstep-num{color:var(--gold)}
.pstep-title{font-family:var(--font-head);font-size:0.82rem;font-weight:700;color:var(--navy-d);margin-bottom:5px;line-height:1.25}
.pstep-desc{font-size:0.74rem;color:var(--text-lt);line-height:1.5}

/* ── OUTCOME BARS ── */
.outcome-bars{display:flex;flex-direction:column;gap:16px;margin:28px 0}
.ob-item{}
.ob-meta{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px}
.ob-label{font-size:0.84rem;font-weight:600;color:var(--navy-d)}
.ob-pct{font-family:var(--font-head);font-size:1rem;font-weight:700;color:var(--teal)}
.ob-track{height:8px;background:var(--gray-lt);border-radius:4px;overflow:hidden}
.ob-fill{height:100%;border-radius:4px;width:0%;transition:width 1.4s cubic-bezier(0.4,0,0.2,1)}
.ob-fill-teal{background:linear-gradient(90deg,var(--teal-d),var(--teal))}
.ob-fill-gold{background:linear-gradient(90deg,#8A6010,var(--gold))}
.ob-sub{font-size:0.75rem;color:var(--gray);margin-top:4px}

/* ── CALLOUT BOXES ── */
.callout{border-radius:var(--radius);padding:22px 26px;margin:28px 0;display:flex;gap:16px;align-items:flex-start}
.callout--info{background:rgba(26,171,152,0.06);border-left:4px solid var(--teal)}
.callout--gold{background:rgba(198,153,58,0.07);border-left:4px solid var(--gold)}
.callout--warn{background:rgba(220,80,50,0.06);border-left:4px solid #DC5032}
.callout--dark{background:rgba(26,39,68,0.06);border-left:4px solid var(--navy)}
.callout-icon{font-size:1.3rem;flex-shrink:0;margin-top:2px}
.callout-title{font-family:var(--font-head);font-size:1rem;font-weight:700;color:var(--navy-d);margin-bottom:5px}
.callout-text{font-size:0.88rem;color:var(--text-lt);line-height:1.72}
.callout-text strong{color:var(--text)}

/* ── COMPARISON TABLE ── */
.comp-table{width:100%;border-collapse:collapse;border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow-sm);margin:28px 0}
.comp-table thead tr{background:var(--navy)}
.comp-table th{font-size:0.7rem;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:rgba(255,255,255,0.7);padding:14px 18px;text-align:left}
.comp-table td{padding:13px 18px;font-size:0.86rem;color:var(--text-lt);border-bottom:1px solid var(--border);vertical-align:middle}
.comp-table tbody tr:last-child td{border-bottom:none}
.comp-table tbody tr:nth-child(odd) td{background:var(--white)}
.comp-table tbody tr:nth-child(even) td{background:var(--gray-lt)}
.comp-table td:first-child{font-weight:600;color:var(--navy);background:var(--off-white)!important;white-space:nowrap}
.td-teal{color:var(--teal-d)!important;font-weight:500!important}
.td-red{color:#B53020!important;font-weight:500!important}
.td-gold{color:#8A6010!important;font-weight:500!important}
.check-yes{color:var(--teal);font-size:1rem}
.check-no{color:#DC5032;font-size:1rem}

/* ── PULL QUOTE ── */
.pullquote{position:relative;margin:40px 0;padding:28px 32px 28px 54px;border-radius:0 var(--radius-lg) var(--radius-lg) 0;background:linear-gradient(135deg,var(--navy) 0%,var(--navy-d) 100%);border-left:5px solid var(--teal)}
.pullquote::before{content:'\201C';position:absolute;left:14px;top:8px;font-family:var(--font-head);font-size:4rem;line-height:1;color:var(--teal);opacity:0.45}
.pullquote-text{font-family:var(--font-head);font-size:1.1rem;font-style:italic;font-weight:400;color:var(--white);line-height:1.72;margin-bottom:12px}
.pullquote-attr{font-size:0.74rem;font-weight:600;letter-spacing:0.08em;color:var(--teal)}

/* ── CANDIDATE CHECKLIST ── */
.candidate-check{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:28px 0}
.cc-item{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px;display:flex;gap:12px;align-items:flex-start;box-shadow:var(--shadow-sm);transition:all var(--transition)}
.cc-item:hover{box-shadow:var(--shadow);transform:translateY(-2px)}
.cc-mark{width:22px;height:22px;border-radius:6px;background:rgba(26,171,152,0.1);border:1.5px solid var(--teal);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;font-size:0.75rem;color:var(--teal);font-weight:700}
.cc-text{font-size:0.84rem;color:var(--text-lt);line-height:1.55}
.cc-text strong{color:var(--text)}

/* ── SIDEBAR ── */
.sidebar{position:sticky;top:82px;display:flex;flex-direction:column;gap:20px}
.s-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:22px;box-shadow:var(--shadow-sm)}
.s-card-dark{background:linear-gradient(135deg,var(--navy) 0%,var(--navy-d) 100%);border:none}
.s-card-teal{background:linear-gradient(135deg,rgba(26,171,152,0.08) 0%,rgba(26,171,152,0.02) 100%);border:1px solid rgba(26,171,152,0.18)}
.s-title{font-family:var(--font-head);font-size:0.9rem;font-weight:700;color:var(--navy-d);margin-bottom:14px;padding-bottom:11px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.s-card-dark .s-title{color:var(--white);border-color:rgba(255,255,255,0.1)}

.toc-list{list-style:none;display:flex;flex-direction:column;gap:2px}
.toc-list a{display:block;font-size:0.79rem;color:var(--text-lt);text-decoration:none;padding:7px 10px;border-radius:var(--radius-sm);transition:all var(--transition);line-height:1.4}
.toc-list a:hover,.toc-list a.active{background:rgba(26,171,152,0.08);color:var(--teal);padding-left:14px}
.toc-list a.active{font-weight:600}

/* healing timeline mini */
.mini-timeline{display:flex;flex-direction:column;gap:0}
.mt-item{display:flex;gap:12px;align-items:stretch}
.mt-line-wrap{display:flex;flex-direction:column;align-items:center;flex-shrink:0}
.mt-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0;margin-top:3px}
.mt-vline{width:2px;flex:1;min-height:16px;margin:3px 0}
.mt-item:last-child .mt-vline{display:none}
.mt-body{padding-bottom:14px}
.mt-week{font-size:0.64rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:2px}
.mt-label{font-size:0.8rem;color:var(--text-lt);line-height:1.4;font-weight:400}

/* quick facts */
.quick-facts{display:flex;flex-direction:column;gap:10px}
.qf-item{display:flex;align-items:flex-start;gap:10px;font-size:0.8rem;color:var(--text-lt);line-height:1.5}
.qf-icon{font-size:0.95rem;flex-shrink:0;margin-top:1px}

/* contact card */
.contact-card{text-align:center;padding:20px}
.cc-headline{font-family:var(--font-head);font-size:1rem;font-weight:700;color:var(--white);margin-bottom:8px}
.cc-sub{font-size:0.78rem;color:rgba(255,255,255,0.5);line-height:1.6;margin-bottom:18px}
