<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OsteoarthritisArticle 04 — Non-Surgical Joint Care</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,500;0,600;0,700;1,400;1,600&family=Figtree:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #1A2744;
  --navy-d: #0F1A30;
  --teal: #1AAB98;
  --teal-d: #148A79;
  --gold: #C6993A;
  --white: #ffffff;
  --off-white: #F5F4EF;
  --gray-lt: #ECEDF2;
  --gray: #8A97AB;
  --gray-dk: #3F5264;
  --text: #171F2D;
  --text-lt: #4A5F75;
  --border: #DDE2EC;
  --font-head: 'Fraunces', Georgia, serif;
  --font-body: 'Figtree', sans-serif;
  --radius-sm: 6px;
  --radius: 14px;
  --radius-lg: 22px;
  --shadow-sm: 0 2px 8px rgba(15,26,48,0.06);
  --shadow: 0 4px 24px rgba(15,26,48,0.09);
  --shadow-lg: 0 12px 48px rgba(15,26,48,0.13);
  --transition: 0.25s ease;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--font-body);background:var(--off-white);color:var(--text);line-height:1.7;overflow-x:hidden}

/* ── TOPBAR ── */
.topbar{position:fixed;top:0;left:0;right:0;z-index:200;height:60px;display:flex;align-items:center;justify-content:space-between;padding:0 48px;background:rgba(10,17,34,0.94);backdrop-filter:blur(16px);border-bottom:1px solid rgba(255,255,255,0.05)}
.topbar-brand{font-family:var(--font-head);font-size:1rem;font-weight:700;color:var(--white);letter-spacing:0.02em}
.topbar-brand span{color:var(--teal)}
.topbar-pills{display:flex;gap:8px;align-items:center}
.pill{font-size:0.68rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:4px 12px;border-radius:20px}
.pill-series{background:rgba(26,171,152,0.14);border:1px solid rgba(26,171,152,0.3);color:var(--teal)}
.pill-num{background:rgba(198,153,58,0.14);border:1px solid rgba(198,153,58,0.3);color:var(--gold)}

/* ── PROGRESS ── */
.progress-bar{position:fixed;top:60px;left:0;right:0;height:2px;background:rgba(255,255,255,0.05);z-index:199}
.progress-fill{height:100%;width:0%;background:linear-gradient(90deg,var(--teal),var(--gold));transition:width 0.1s linear}

/* ── HERO ── */
.hero{min-height:100vh;background:var(--navy-d);position:relative;overflow:hidden;padding-top:60px;display:flex;flex-direction:column;justify-content:flex-end}

/* animated mesh background */
.hero-mesh{position:absolute;inset:0;pointer-events:none;overflow:hidden}
.mesh-orb{position:absolute;border-radius:50%;filter:blur(80px);opacity:0.18}
.mesh-orb-1{width:600px;height:600px;background:radial-gradient(circle,var(--teal) 0%,transparent 70%);top:-100px;left:-80px;animation:drift1 14s ease-in-out infinite alternate}
.mesh-orb-2{width:500px;height:500px;background:radial-gradient(circle,var(--gold) 0%,transparent 70%);top:40%;right:-60px;animation:drift2 18s ease-in-out infinite alternate}
.mesh-orb-3{width:400px;height:400px;background:radial-gradient(circle,#3A5AAA 0%,transparent 70%);bottom:-80px;left:35%;animation:drift3 12s ease-in-out infinite alternate}
@keyframes drift1{to{transform:translate(60px,80px)}}
@keyframes drift2{to{transform:translate(-50px,60px)}}
@keyframes drift3{to{transform:translate(40px,-60px)}}

.hero-noise{position:absolute;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:1}

/* Hero grid overlay – decorative lines */
.hero-grid{position:absolute;inset:0;pointer-events:none;z-index:1;
  background-image:
    linear-gradient(rgba(255,255,255,0.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,0.025) 1px,transparent 1px);
  background-size:80px 80px}

/* floating joint SVG */
.hero-joint-wrap{position:absolute;right:6%;top:50%;transform:translateY(-50%);z-index:2;width:340px;opacity:0.92;animation:floatJoint 6s ease-in-out infinite}
@keyframes floatJoint{0%,100%{transform:translateY(-50%) translateY(0)}50%{transform:translateY(-50%) translateY(-18px)}}

.hero-content{position:relative;z-index:3;padding:80px 80px 80px 80px;max-width:820px}

.hero-eyebrow{display:flex;align-items:center;gap:14px;margin-bottom:28px}
.eyebrow-tag{font-size:0.7rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold);border:1px solid rgba(198,153,58,0.35);padding:4px 12px;border-radius:4px;font-family:var(--font-head);font-style:italic}
.eyebrow-label{font-size:0.68rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:var(--gray)}
.eyebrow-rule{flex:1;max-width:60px;height:1px;background:rgba(255,255,255,0.12)}

.hero-kicker{font-size:0.78rem;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;color:var(--teal);margin-bottom:16px}

.hero-title{font-family:var(--font-head);font-size:clamp(2.2rem,4.8vw,3.8rem);font-weight:700;line-height:1.1;color:var(--white);margin-bottom:28px}
.hero-title .accent{color:var(--teal);font-style:italic}
.hero-title .accent-gold{color:var(--gold)}

.hero-desc{font-size:1.05rem;font-weight:300;color:rgba(255,255,255,0.58);max-width:600px;line-height:1.8;margin-bottom:48px}

/* Author strip */
.author-strip{display:flex;align-items:center;gap:0;border-top:1px solid rgba(255,255,255,0.08);padding-top:32px;flex-wrap:wrap;gap:28px}
.author-avatar{width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,var(--teal-d),var(--navy));border:2px solid rgba(26,171,152,0.4);display:flex;align-items:center;justify-content:center;font-family:var(--font-head);font-weight:700;font-size:0.9rem;color:var(--white);flex-shrink:0}
.author-info{}
.author-name{font-size:0.88rem;font-weight:600;color:var(--white);margin-bottom:2px}
.author-cred{font-size:0.74rem;color:var(--gray)}
.strip-divider{width:1px;height:36px;background:rgba(255,255,255,0.1)}
.strip-stat{text-align:center}
.strip-stat-val{font-family:var(--font-head);font-size:1.15rem;font-weight:700;color:var(--white);display:block}
.strip-stat-lbl{font-size:0.66rem;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:var(--gray)}

/* Scroll cue */
.hero-scroll{position:absolute;bottom:36px;left:80px;z-index:3;display:flex;align-items:center;gap:10px;color:var(--gray);font-size:0.72rem;font-weight:500;letter-spacing:0.1em;text-transform:uppercase}
.scroll-arrow{display:flex;flex-direction:column;gap:3px;animation:scrollBounce 2s ease-in-out infinite}
@keyframes scrollBounce{0%,100%{transform:translateY(0)}50%{transform:translateY(5px)}}
.scroll-arrow span{display:block;width:1px;background:rgba(255,255,255,0.25)}
.scroll-arrow span:nth-child(1){height:10px}
.scroll-arrow span:nth-child(2){height:6px;margin-left:3px}
.scroll-arrow span:nth-child(3){height:3px;margin-left:6px}

/* ── TREATMENT OVERVIEW BAND ── */
.overview-band{background:var(--navy);padding:56px 80px}
.overview-inner{max-width:1100px;margin:0 auto}
.band-label{font-size:0.68rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:var(--teal);margin-bottom:16px}
.band-title{font-family:var(--font-head);font-size:clamp(1.5rem,2.5vw,2rem);font-weight:700;color:var(--white);margin-bottom:40px;line-height:1.25}
.band-title em{color:var(--gold);font-style:italic}

.treatment-pills-row{display:flex;flex-wrap:wrap;gap:10px}
.tpill{display:inline-flex;align-items:center;gap:8px;padding:10px 18px;border-radius:30px;font-size:0.8rem;font-weight:500;cursor:default;transition:all var(--transition)}
.tpill-teal{background:rgba(26,171,152,0.12);border:1px solid rgba(26,171,152,0.25);color:rgba(255,255,255,0.7)}
.tpill-teal:hover{background:rgba(26,171,152,0.22);color:var(--white)}
.tpill-gold{background:rgba(198,153,58,0.12);border:1px solid rgba(198,153,58,0.25);color:rgba(255,255,255,0.7)}
.tpill-gold:hover{background:rgba(198,153,58,0.22);color:var(--white)}
.tpill-gray{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.5)}
.tpill .tpill-icon{font-size:1rem}

/* ── BODY LAYOUT ── */
.article-body{max-width:1200px;margin:0 auto;padding:80px 48px 120px;display:grid;grid-template-columns:1fr 308px;gap:64px;align-items:start}

/* ── CONTENT SECTIONS ── */
.main-content{min-width:0}
.section{margin-bottom:72px}

.sec-eyebrow{display:flex;align-items:center;gap:12px;margin-bottom:18px}
.sec-num{font-family:var(--font-head);font-size:0.72rem;font-style:italic;color:var(--teal);border:1px solid rgba(26,171,152,0.3);padding:2px 9px;border-radius:4px}
.sec-cat{font-size:0.67rem;font-weight:600;letter-spacing:0.13em;text-transform:uppercase;color:var(--gray)}

.sec-heading{font-family:var(--font-head);font-size:clamp(1.5rem,2.8vw,2.1rem);font-weight:700;color:var(--navy-d);line-height:1.2;margin-bottom:18px}
.sec-heading em{font-style:italic;color:var(--teal)}
.sec-heading .gold{color:var(--gold)}

.prose{font-size:0.98rem;color:var(--text-lt);line-height:1.88;margin-bottom:18px}
.prose strong{color:var(--text);font-weight:600}
.prose a{color:var(--teal);text-decoration:none;border-bottom:1px solid rgba(26,171,152,0.3);transition:border-color var(--transition)}
.prose a:hover{border-color:var(--teal)}

.section-rule{width:56px;height:3px;background:linear-gradient(90deg,var(--teal),var(--gold));border-radius:2px;margin:48px 0}

/* ── TREATMENT CARDS GRID ── */
.treatment-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin:28px 0}
.tcard{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:26px 24px;transition:all var(--transition);position:relative;overflow:hidden}
.tcard::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
.tcard-teal::before{background:linear-gradient(90deg,var(--teal),rgba(26,171,152,0.3))}
.tcard-gold::before{background:linear-gradient(90deg,var(--gold),rgba(198,153,58,0.3))}
.tcard-navy::before{background:linear-gradient(90deg,var(--navy),rgba(26,39,68,0.3))}
.tcard-gray::before{background:linear-gradient(90deg,var(--gray-dk),rgba(63,82,100,0.3))}
.tcard:hover{box-shadow:var(--shadow);transform:translateY(-3px)}
.tcard-icon{font-size:1.7rem;margin-bottom:12px;display:block}
.tcard-name{font-family:var(--font-head);font-size:1.05rem;font-weight:700;color:var(--navy-d);margin-bottom:8px}
.tcard-label{display:inline-block;font-size:0.65rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:2px 8px;border-radius:3px;margin-bottom:10px}
.label-evidence-high{background:rgba(26,171,152,0.1);color:var(--teal-d)}
.label-evidence-mod{background:rgba(198,153,58,0.1);color:#8A6010}
.label-evidence-emerging{background:rgba(63,82,100,0.1);color:var(--gray-dk)}
.tcard-desc{font-size:0.86rem;color:var(--text-lt);line-height:1.65}
.tcard-desc strong{color:var(--text)}

/* ── EVIDENCE TABLE ── */
.ev-table{width:100%;border-collapse:collapse;border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow-sm);margin:28px 0}
.ev-table thead tr{background:var(--navy)}
.ev-table th{font-size:0.72rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:rgba(255,255,255,0.75);padding:14px 18px;text-align:left}
.ev-table td{padding:12px 18px;font-size:0.88rem;color:var(--text-lt);border-bottom:1px solid var(--border);vertical-align:middle}
.ev-table tbody tr:last-child td{border-bottom:none}
.ev-table tbody tr:nth-child(odd) td{background:var(--white)}
.ev-table tbody tr:nth-child(even) td{background:var(--gray-lt)}
.ev-table td:first-child{font-weight:600;color:var(--navy);background:var(--off-white)!important;white-space:nowrap}
.evidence-dot{display:inline-flex;gap:4px;align-items:center}
.dot{width:8px;height:8px;border-radius:50%;background:var(--gray-lt)}
.dot.filled-teal{background:var(--teal)}
.dot.filled-gold{background:var(--gold)}

/* ── LIFESTYLE PILLARS ── */
.pillar-row{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:28px 0}
.pillar{border-radius:var(--radius-lg);padding:26px 20px;text-align:center;transition:transform var(--transition),box-shadow var(--transition)}
.pillar:hover{transform:translateY(-4px);box-shadow:var(--shadow)}
.pillar-1{background:linear-gradient(160deg,rgba(26,171,152,0.08),rgba(26,171,152,0.02));border:1px solid rgba(26,171,152,0.18)}
.pillar-2{background:linear-gradient(160deg,rgba(198,153,58,0.08),rgba(198,153,58,0.02));border:1px solid rgba(198,153,58,0.18)}
.pillar-3{background:linear-gradient(160deg,rgba(26,39,68,0.06),rgba(26,39,68,0.01));border:1px solid rgba(26,39,68,0.12)}
.pillar-icon{font-size:2rem;margin-bottom:12px;display:block}
.pillar-name{font-family:var(--font-head);font-size:0.95rem;font-weight:700;color:var(--navy-d);margin-bottom:8px}
.pillar-text{font-size:0.8rem;color:var(--text-lt);line-height:1.6}

/* ── CALLOUT BOXES ── */
.callout{border-radius:var(--radius);padding:22px 26px;margin:28px 0;display:flex;gap:16px;align-items:flex-start}
.callout--info{background:rgba(26,171,152,0.06);border-left:4px solid var(--teal)}
.callout--gold{background:rgba(198,153,58,0.07);border-left:4px solid var(--gold)}
.callout--navy{background:rgba(26,39,68,0.06);border-left:4px solid var(--navy)}
.callout--warn{background:rgba(220,80,50,0.06);border-left:4px solid #DC5032}
.callout-icon{font-size:1.35rem;flex-shrink:0;margin-top:2px}
.callout-title{font-family:var(--font-head);font-size:1rem;font-weight:700;color:var(--navy-d);margin-bottom:5px}
.callout-text{font-size:0.88rem;color:var(--text-lt);line-height:1.7}
.callout-text strong{color:var(--text)}

/* ── PULL QUOTE ── */
.pullquote{position:relative;margin:40px 0;padding:28px 32px 28px 52px;border-radius:0 var(--radius-lg) var(--radius-lg) 0;background:linear-gradient(135deg,var(--navy) 0%,var(--navy-d) 100%);border-left:5px solid var(--teal)}
.pullquote::before{content:'\201C';position:absolute;left:14px;top:8px;font-family:var(--font-head);font-size:3.8rem;line-height:1;color:var(--teal);opacity:0.5}
.pullquote-text{font-family:var(--font-head);font-size:1.12rem;font-style:italic;font-weight:400;color:var(--white);line-height:1.7;margin-bottom:12px}
.pullquote-attr{font-size:0.76rem;font-weight:600;letter-spacing:0.08em;color:var(--teal)}

/* ── INJECTION COMPARISON ── */
.inject-cards{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin:28px 0}
.inject-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);padding:22px 18px;box-shadow:var(--shadow-sm);transition:all var(--transition)}
.inject-card:hover{box-shadow:var(--shadow);transform:translateY(-2px)}
.ic-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.ic-name{font-family:var(--font-head);font-size:0.95rem;font-weight:700;color:var(--navy-d)}
.ic-badge{font-size:0.62rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:3px 8px;border-radius:3px}
.ic-badge-teal{background:rgba(26,171,152,0.1);color:var(--teal-d)}
.ic-badge-gold{background:rgba(198,153,58,0.1);color:#8A6010}
.ic-badge-navy{background:rgba(26,39,68,0.1);color:var(--navy)}
.ic-detail{font-size:0.81rem;color:var(--text-lt);line-height:1.6;margin-bottom:10px}
.ic-bar-label{font-size:0.65rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--gray);margin-bottom:4px}
.ic-bar-track{height:4px;background:var(--gray-lt);border-radius:2px;overflow:hidden}
.ic-bar-fill{height:100%;border-radius:2px;transition:width 1.2s ease}
.ic-bar-teal{background:var(--teal)}
.ic-bar-gold{background:var(--gold)}
.ic-bar-navy{background:var(--navy)}

/* ── MYTH/FACT ── */
.myth-grid{display:flex;flex-direction:column;gap:14px;margin:28px 0}
.myth-item{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;display:grid;grid-template-columns:auto 1fr;box-shadow:var(--shadow-sm)}
.myth-label{padding:20px 16px;font-size:0.66rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;writing-mode:vertical-rl;text-orientation:mixed;display:flex;align-items:center;justify-content:center;min-width:44px}
.myth-label-myth{background:rgba(220,80,50,0.08);color:#DC5032;border-right:3px solid #DC5032}
.myth-label-fact{background:rgba(26,171,152,0.08);color:var(--teal-d);border-right:3px solid var(--teal)}
.myth-content{padding:18px 20px}
.myth-heading{font-family:var(--font-head);font-size:0.95rem;font-weight:700;color:var(--navy-d);margin-bottom:5px}
.myth-text{font-size:0.84rem;color:var(--text-lt);line-height:1.6}

/* ── STEPS TIMELINE ── */
.timeline{position:relative;padding-left:36px;margin:28px 0}
.timeline::before{content:'';position:absolute;left:13px;top:8px;bottom:8px;width:2px;background:linear-gradient(to bottom,var(--teal),var(--gold));border-radius:2px}
.t-item{position:relative;margin-bottom:32px}
.t-item:last-child{margin-bottom:0}
.t-dot{position:absolute;left:-30px;top:4px;width:16px;height:16px;border-radius:50%;background:var(--white);border:3px solid var(--teal);box-shadow:0 0 0 3px rgba(26,171,152,0.15)}
.t-last .t-dot{border-color:var(--gold);box-shadow:0 0 0 3px rgba(198,153,58,0.15)}
.t-step-label{font-size:0.66rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--teal);margin-bottom:3px}
.t-last .t-step-label{color:var(--gold)}
.t-step-heading{font-family:var(--font-head);font-size:1rem;font-weight:700;color:var(--navy-d);margin-bottom:6px}
.t-step-body{font-size:0.88rem;color:var(--text-lt);line-height:1.7}

/* ── SIDEBAR ── */
.sidebar{position:sticky;top:80px;display:flex;flex-direction:column;gap:20px}
.s-card{background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:22px;box-shadow:var(--shadow-sm)}
.s-card-dark{background:linear-gradient(135deg,var(--grey) 0%,var(--navy-d) 100%);border:none}
.s-title{font-family:var(--font-head);font-size:0.92rem;font-weight:700;color:var(--navy-d);margin-bottom:14px;padding-bottom:12px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.s-card-dark .s-title{color:var(--white);border-color:rgba(255,255,255,0.1)}

/* TOC */
.toc-list{list-style:none;display:flex;flex-direction:column;gap:2px}
.toc-list a{display:block;font-size:0.8rem;color:var(--text-lt);text-decoration:none;padding:7px 10px;border-radius:var(--radius-sm);transition:all var(--transition);line-height:1.4}
.toc-list a:hover,.toc-list a.active{background:rgba(26,171,152,0.08);color:var(--teal);padding-left:14px}
.toc-list a.active{font-weight:600}

/* Risk factors */
.risk-list{list-style:none;display:flex;flex-direction:column;gap:8px}
.risk-item{display:flex;align-items:flex-start;gap:10px;font-size:0.81rem;color:rgba(255,255,255,0.6);line-height:1.5}
.risk-icon{width:26px;height:26px;border-radius:8px;background:rgba(255,255,255,0.07);display:flex;align-items:center;justify-content:center;font-size:0.85rem;flex-shrink:0}

/* Pain tracker visual */
.pain-scale{margin:12px 0}
.pain-track{height:8px;border-radius:4px;background:linear-gradient(90deg,#1AAB98 0%,#C6993A 50%,#DC5032 100%);margin-bottom:6px;position:relative}
.pain-markers{display:flex;justify-content:space-between;font-size:0.66rem;color:var(--gray);font-weight:500}
