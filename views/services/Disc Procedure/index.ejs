<style>
  :root {
    --navy: #0A2342;
    --navy-d: #061629;
    --teal: #1B998B;
    --teal-d: #147a6e;
    --gold: #C9A84C;
    --white: #ffffff;
    --off-white: #F5F7FA;
    --gray-lt: #EEF1F6;
    --gray: #8899AA;
    --gray-dk: #455A6E;
    --text: #1A2B3C;
    --text-lt: #546E82;
    --border: #DDE4EE;
    --font-head: 'Playfair Display', Georgia, serif;
    --font-body: 'DM Sans', 'Segoe UI', sans-serif;
    --radius-sm: 6px;
    --radius: 14px;
    --radius-lg: 22px;
    --shadow-sm: 0 2px 8px rgba(10,35,66,0.06);
    --shadow: 0 4px 24px rgba(10,35,66,0.09);
    --shadow-lg: 0 12px 48px rgba(10,35,66,0.12);
    --transition: 0.25s ease;
  }

  *, *::before, *::after { box-sizing:border-box; margin:0; padding:0 }
  body { font-family:var(--font-body); color:var(--text); background:var(--white); overflow-x:hidden; line-height:1.7 }
  img { max-width:100%; display:block }
  a { text-decoration:none; color:inherit }

  /* ── HERO ── */
  .service-hero {
    background: linear-gradient(135deg, var(--navy-d) 0%, var(--navy) 100%);
    padding: 72px 5% 0;
    position: relative;
    overflow: hidden;
  }
  .service-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(-55deg,
      transparent 0px, transparent 18px,
      rgba(255,255,255,0.018) 18px, rgba(255,255,255,0.018) 20px);
  }
  .service-hero::after {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(27,153,139,0.18) 0%, transparent 65%);
    pointer-events: none;
  }
  .service-hero-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 56px;
    align-items: flex-end;
    position: relative;
    z-index: 1;
  }
  .service-hero-content { padding-bottom: 56px }

  .breadcrumb { display: flex; align-items: center; gap: 8px; margin-bottom: 20px; flex-wrap: wrap }
  .breadcrumb a { font-size: 0.78rem; color: rgba(255,255,255,0.50); transition: color var(--transition) }
  .breadcrumb a:hover { color: var(--gold) }
  .breadcrumb span { font-size: 0.78rem; color: rgba(255,255,255,0.25) }
  .breadcrumb .current { font-size: 0.78rem; color: var(--gold); font-weight: 500 }

  .section-label {
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 12px;
    display: flex; align-items: center; gap: 10px;
  }
  .section-label::before { content: ''; display: inline-block; width: 28px; height: 2px; background: var(--teal); border-radius: 2px }

  .service-hero h1 {
    font-family: var(--font-head);
    font-size: clamp(1.9rem, 3.8vw, 2.9rem);
    font-weight: 700; color: var(--white);
    line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 16px;
  }
  .service-hero h1 em { color: var(--gold); font-style: italic }
  .service-hero-desc { font-size: 1rem; color: rgba(255,255,255,0.62); line-height: 1.78; max-width: 520px; margin-bottom: 32px }

  .hero-badges { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 36px }
  .hero-badge-pill {
    display: inline-flex; align-items: center; gap: 7px;
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.82); font-size: 0.78rem; font-weight: 500;
    padding: 6px 14px; border-radius: 50px;
  }
  .hero-badge-pill i { color: var(--teal); font-size: 0.72rem }
  .hero-actions { display: flex; gap: 14px; flex-wrap: wrap }

  .btn-primary {
    background: var(--teal); color: var(--white); padding: 13px 28px; border-radius: 50px;
    font-family: var(--font-body); font-size: 0.88rem; font-weight: 600;
    display: inline-flex; align-items: center; gap: 9px;
    transition: all var(--transition); border: none; cursor: pointer;
  }
  .btn-primary:hover { background: var(--teal-d); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(27,153,139,0.35); color: var(--white) }
  .btn-ghost {
    background: transparent; color: var(--white); padding: 12px 26px; border-radius: 50px;
    font-family: var(--font-body); font-size: 0.88rem; font-weight: 600;
    display: inline-flex; align-items: center; gap: 9px;
    border: 1.5px solid rgba(255,255,255,0.32); transition: all var(--transition);
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.10); border-color: rgba(255,255,255,0.60); color: var(--white) }

  .service-hero-img-wrap { position: relative; align-self: flex-end }
  .service-hero-img { width: 100%; height: 400px; object-fit: cover; border-radius: var(--radius-lg) var(--radius-lg) 0 0; display: block; box-shadow: 0 -8px 48px rgba(0,0,0,0.25) }
  .hero-img-badge { position: absolute; top: 20px; left: -16px; background: var(--white); border-radius: var(--radius); padding: 14px 18px; box-shadow: var(--shadow-lg); text-align: center; min-width: 110px }
  .hero-img-badge-num { font-family: var(--font-head); font-size: 1.5rem; font-weight: 700; color: var(--teal); line-height: 1 }
  .hero-img-badge-label { font-size: 0.65rem; color: var(--text-lt); margin-top: 3px; line-height: 1.4 }

  /* ── 3 TREATMENT TYPES STRIP ── */
  .treatment-strip { background: var(--teal); padding: 0 }
  .treatment-strip-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 0;
  }
  .treatment-type {
    display: flex; align-items: center; gap: 16px;
    padding: 28px 28px; border-right: 1px solid rgba(255,255,255,0.18);
  }
  .treatment-type:last-child { border-right: none }
  .treatment-type-icon { width: 48px; height: 48px; background: rgba(255,255,255,0.15); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0 }
  .treatment-type-icon i { color: var(--white); font-size: 1.1rem }
  .treatment-type strong { display: block; font-size: 0.92rem; font-weight: 700; color: var(--white); margin-bottom: 3px }
  .treatment-type span { font-size: 0.76rem; color: rgba(255,255,255,0.68); line-height: 1.4 }

  /* ── QUICK FACTS ── */
  .quick-facts { background: var(--navy); padding: 0 }
  .quick-facts-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 0 }
  .fact-item { display: flex; align-items: center; gap: 14px; padding: 22px 28px; border-right: 1px solid rgba(255,255,255,0.10) }
  .fact-item:last-child { border-right: none }
  .fact-icon { width: 40px; height: 40px; background: rgba(27,153,139,0.20); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0 }
  .fact-icon i { color: var(--teal); font-size: 0.95rem }
  .fact-text strong { display: block; font-size: 0.85rem; font-weight: 700; color: var(--white); margin-bottom: 2px }
  .fact-text span { font-size: 0.75rem; color: rgba(255,255,255,0.50) }

  /* ── MAIN CONTENT ── */
  .service-main { padding: 80px 5%; background: var(--white) }
  .service-main-grid { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 340px; gap: 56px; align-items: flex-start }

  .content-section { margin-bottom: 52px }
  .content-section:last-child { margin-bottom: 0 }
  .content-label {
    font-size: 0.70rem; font-weight: 700; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--teal); margin-bottom: 10px;
    display: flex; align-items: center; gap: 8px;
  }
  .content-label::before { content: ''; width: 20px; height: 2px; background: var(--gold); display: inline-block; border-radius: 2px }
  .content-h2 { font-family: var(--font-head); font-size: clamp(1.5rem, 2.5vw, 2rem); color: var(--navy); font-weight: 700; margin-bottom: 16px; letter-spacing: -0.02em; line-height: 1.3 }
  .content-h2 em { color: var(--teal); font-style: italic }
  .content-p { font-size: 0.95rem; color: var(--text-lt); line-height: 1.82; margin-bottom: 16px }
  .content-p:last-child { margin-bottom: 0 }
  .content-p strong { color: var(--navy) }

  /* 3 Treatment Method Cards */
  .method-cards { display: flex; flex-direction: column; gap: 20px; margin-top: 24px }
  .method-card {
    background: var(--white);
    border: 1.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px 26px;
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 20px;
    align-items: flex-start;
    transition: all var(--transition);
    position: relative;
    overflow: hidden;
  }
  .method-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: var(--teal);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.35s ease;
  }
  .method-card:hover { box-shadow: var(--shadow); border-color: var(--teal); transform: translateX(4px) }
  .method-card:hover::before { transform: scaleY(1) }
  .method-card-num {
    width: 56px; height: 56px;
    background: var(--navy);
    border-radius: var(--radius);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .method-card-num i { color: var(--gold); font-size: 1.2rem }
  .method-card-tag {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.10em;
    text-transform: uppercase; color: var(--teal);
    background: rgba(27,153,139,0.08); border: 1px solid rgba(27,153,139,0.18);
    padding: 3px 10px; border-radius: 50px; margin-bottom: 8px;
    width: fit-content;
  }
  .method-card h3 { font-family: var(--font-head); font-size: 1.05rem; color: var(--navy); font-weight: 700; margin-bottom: 8px }
  .method-card p { font-size: 0.84rem; color: var(--text-lt); line-height: 1.72 }
  .method-card p strong { color: var(--navy) }

  /* Disc Types Grid */
  .disc-types { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-top: 24px }
  .disc-type {
    background: var(--off-white);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 20px 16px;
    text-align: center;
    transition: all var(--transition);
    position: relative;
    overflow: hidden;
  }
  .disc-type::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--teal), var(--gold));
    opacity: 0;
    transition: opacity var(--transition);
  }
  .disc-type:hover { border-color: var(--teal); box-shadow: var(--shadow-sm); transform: translateY(-3px) }
  .disc-type:hover::after { opacity: 1 }
  .disc-type-icon { width: 44px; height: 44px; background: rgba(27,153,139,0.10); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 12px; border: 1px solid rgba(27,153,139,0.18) }
  .disc-type-icon i { color: var(--teal); font-size: 0.95rem }
  .disc-type h4 { font-family: var(--font-head); font-size: 0.92rem; color: var(--navy); font-weight: 700; margin-bottom: 6px }
  .disc-type p { font-size: 0.78rem; color: var(--text-lt); line-height: 1.60 }

  /* Checklist */
  .check-list { display: flex; flex-direction: column; gap: 10px; margin-top: 20px }
  .check-item { display: flex; align-items: flex-start; gap: 12px; padding: 14px 16px; background: var(--off-white); border-radius: var(--radius-sm); border: 1px solid var(--border) }
  .check-item i { color: var(--teal); margin-top: 2px; flex-shrink: 0 }
  .check-item span { font-size: 0.88rem; color: var(--text); line-height: 1.5 }
  .check-item span strong { color: var(--navy) }

  /* Warning signs */
  .warning-box {
    background: rgba(226,75,74,0.05);
    border: 1.5px solid rgba(226,75,74,0.18);
    border-radius: var(--radius);
    padding: 20px 22px;
    margin-top: 20px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .warning-box i { color: #e24b4a; font-size: 1.1rem; flex-shrink: 0; margin-top: 2px }
  .warning-box h4 { font-family: var(--font-head); font-size: 0.92rem; color: #c93535; font-weight: 700; margin-bottom: 6px }
  .warning-box p { font-size: 0.83rem; color: var(--text-lt); line-height: 1.65 }

  /* Recovery timeline */
  .steps-grid { display: flex; flex-direction: column; gap: 0; margin-top: 20px; position: relative }
  .steps-grid::before { content: ''; position: absolute; left: 19px; top: 20px; bottom: 20px; width: 2px; background: linear-gradient(to bottom, var(--teal), rgba(27,153,139,0.10)) }
  .step-item { display: flex; gap: 20px; align-items: flex-start; padding: 18px 0; border-bottom: 1px solid var(--border); position: relative }
  .step-item:last-child { border-bottom: none }
  .step-num { width: 40px; height: 40px; background: var(--navy); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-family: var(--font-head); font-size: 0.88rem; font-weight: 700; color: var(--gold); border: 3px solid var(--white); box-shadow: 0 0 0 2px var(--navy); z-index: 1 }
  .step-body h4 { font-family: var(--font-head); font-size: 0.95rem; color: var(--navy); font-weight: 600; margin-bottom: 4px }
  .step-body p { font-size: 0.83rem; color: var(--text-lt); line-height: 1.65 }
  .step-badge { display: inline-block; font-size: 0.70rem; font-weight: 600; color: var(--teal-d); background: rgba(27,153,139,0.08); border: 1px solid rgba(27,153,139,0.18); padding: 2px 10px; border-radius: 50px; margin-bottom: 5px }

  /* FAQ */
  .faq-list { display: flex; flex-direction: column; gap: 10px; margin-top: 20px }
  .faq-item { background: var(--white); border: 1.5px solid var(--border); border-radius: var(--radius); overflow: hidden; transition: border-color var(--transition) }
  .faq-item:hover { border-color: var(--teal) }
  .faq-q { width: 100%; background: none; border: none; padding: 18px 20px; display: flex; align-items: center; justify-content: space-between; gap: 16px; cursor: pointer; text-align: left; font-family: var(--font-body); font-size: 0.9rem; font-weight: 600; color: var(--navy); transition: color var(--transition) }
  .faq-q:hover, .faq-q.open { color: var(--teal) }
  .faq-icon { width: 26px; height: 26px; background: var(--gray-lt); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--navy); font-size: 0.72rem; flex-shrink: 0; transition: all var(--transition) }
  .faq-q.open .faq-icon { background: var(--teal); color: var(--white); transform: rotate(45deg) }
  .faq-a { display: none; padding: 14px 20px 18px; font-size: 0.87rem; color: var(--text-lt); line-height: 1.75; border-top: 1px solid var(--border) }
  .faq-a.open { display: block }

  /* ── SIDEBAR ── */
  .sidebar { display: flex; flex-direction: column; gap: 20px }
  .sidebar-card { background: var(--off-white); border: 1.5px solid var(--border); border-radius: var(--radius-lg); padding: 26px 24px }
  .sidebar-card-title { font-family: var(--font-head); font-size: 1rem; color: var(--navy); font-weight: 700; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid var(--border); position: relative }
  .sidebar-card-title::after { content: ''; position: absolute; bottom: -1px; left: 0; width: 32px; height: 2px; background: var(--gold) }
  .appt-sidebar { background: linear-gradient(135deg, var(--navy-d) 0%, var(--navy) 100%); border-color: var(--navy) }
  .appt-sidebar .sidebar-card-title { color: var(--white); border-bottom-color: rgba(255,255,255,0.12) }
  .appt-sidebar p { font-size: 0.84rem; color: rgba(255,255,255,0.58); line-height: 1.65; margin-bottom: 20px }
  .appt-sidebar .btn-primary { width: 100%; justify-content: center; margin-bottom: 10px }
  .appt-sidebar .btn-call { width: 100%; display: flex; align-items: center; justify-content: center; gap: 9px; padding: 12px; border-radius: 50px; border: 1.5px solid rgba(255,255,255,0.25); color: var(--white); font-size: 0.85rem; font-weight: 600; transition: all var(--transition) }
  .appt-sidebar .btn-call:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.55) }
  .appt-sidebar .btn-call i { color: var(--teal); font-size: 0.8rem }
  .related-link { display: flex; align-items: center; gap: 12px; padding: 11px 0; border-bottom: 1px solid var(--border); transition: all var(--transition); font-size: 0.87rem; color: var(--text); font-weight: 500 }
  .related-link:last-child { border-bottom: none; padding-bottom: 0 }
  .related-link:hover { color: var(--teal); padding-left: 4px }
  .related-link i { color: var(--teal); font-size: 0.62rem; flex-shrink: 0 }
  .doc-card { display: flex; align-items: center; gap: 14px; margin-bottom: 16px }
  .doc-avatar { width: 56px; height: 56px; border-radius: 50%; object-fit: cover; object-position: top; flex-shrink: 0; border: 2px solid var(--teal) }
  .doc-name { font-family: var(--font-head); font-size: 0.95rem; font-weight: 700; color: var(--navy); margin-bottom: 2px }
  .doc-spec { font-size: 0.75rem; color: var(--teal) }
  .doc-creds { display: flex; flex-direction: column; gap: 6px }
  .doc-cred { display: flex; align-items: center; gap: 8px; font-size: 0.80rem; color: var(--text-lt) }
  .doc-cred i { color: var(--gold); font-size: 0.72rem; flex-shrink: 0 }

  /* ── OTHER SERVICES ── */
  .other-services { padding: 72px 5%; background: var(--off-white); border-top: 1px solid var(--border) }
  .other-services-inner { max-width: 1100px; margin: 0 auto }
  .other-services h2 { font-family: var(--font-head); font-size: clamp(1.5rem, 2.5vw, 2rem); color: var(--navy); font-weight: 700; margin-bottom: 32px; letter-spacing: -0.02em }
  .other-services h2 em { color: var(--teal); font-style: italic }
  .other-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px }
  .other-card { background: var(--white); border: 1.5px solid var(--border); border-radius: var(--radius); padding: 22px 20px; display: flex; align-items: flex-start; gap: 14px; transition: all var(--transition) }
  .other-card:hover { border-color: var(--teal); box-shadow: var(--shadow-sm); transform: translateY(-3px); color: inherit }
  .other-card-icon { width: 42px; height: 42px; background: rgba(27,153,139,0.08); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0; border: 1px solid rgba(27,153,139,0.15) }
  .other-card-icon i { color: var(--teal); font-size: 0.9rem }
  .other-card h4 { font-family: var(--font-head); font-size: 0.92rem; color: var(--navy); font-weight: 600; margin-bottom: 4px }
  .other-card p { font-size: 0.78rem; color: var(--text-lt); line-height: 1.55 }

