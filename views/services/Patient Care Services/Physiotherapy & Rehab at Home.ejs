<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dr. Sarish Sharma – Orthopedic Specialist | South Delhi</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/about.css">
  <link rel="stylesheet" href="/home.css">
  <link rel="stylesheet" href="/service.css">
</head>

<style>

  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,500;0,600;0,700;1,400;1,600&family=Figtree:wght@300;400;500;600&display=swap');

  :root {
    --navy: #1A2744;
    --navy-d: #0F1A30;
    --teal: #1AAB98;
    --teal-d: #148A79;
    --gold: #C6993A;
    --white: #ffffff;
    --off-white: #F5F4EF;
    --gray-lt: #ECEDF2;
    --gray: #8A97AB;
    --gray-dk: #3F5264;
    --text: #171F2D;
    --text-lt: #4A5F75;
    --border: #DDE2EC;
    --font-head: 'Fraunces', Georgia, serif;
    --font-body: 'Figtree', sans-serif;

    --radius-sm: 6px;
    --radius: 14px;
    --radius-lg: 22px;
    --shadow-sm: 0 2px 8px rgba(15, 26, 48, 0.06);
    --shadow: 0 4px 24px rgba(15, 26, 48, 0.09);
    --shadow-lg: 0 12px 48px rgba(15, 26, 48, 0.13);
    --transition: 0.25s ease;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-body);
    color: var(--text);
    background: var(--off-white);
    line-height: 1.65;
    overflow-x: hidden;
  }

  /* ── NAV styles removed — using your own navbar ── */

  /* ── HERO ── */
  .hero {
    position: relative;
    min-height: 90vh;
    background: linear-gradient(135deg, var(--navy-d) 0%, var(--navy) 55%, #1e3a5f 100%);
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 6rem 2rem 4rem;
  }

  .hero-mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 80% 50%, rgba(26, 171, 152, 0.13) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 15% 80%, rgba(198, 153, 58, 0.1) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(26, 171, 152, 0.15);
    border: 1px solid rgba(26, 171, 152, 0.35);
    color: var(--teal);
    padding: 0.35rem 1rem;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1.4rem;
    animation: fadeUp 0.6s ease forwards;
  }

  .hero-badge::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--teal);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {

    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }

    50% {
      opacity: 0.5;
      transform: scale(1.4);
    }
  }

  .hero-h1 {
    font-family: var(--font-head);
    font-size: clamp(2.4rem, 4.5vw, 3.6rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.12;
    margin-bottom: 1.2rem;
    animation: fadeUp 0.7s 0.1s ease both;
  }

  .hero-h1 em {
    font-style: italic;
    color: var(--teal);
  }

  .hero-desc {
    font-size: 1.05rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.7);
    max-width: 480px;
    margin-bottom: 2.2rem;
    animation: fadeUp 0.7s 0.2s ease both;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    animation: fadeUp 0.7s 0.3s ease both;
  }

  .btn-primary {
    background: var(--teal);
    color: var(--white);
    border: none;
    padding: 0.85rem 1.8rem;
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background var(--transition), transform var(--transition), box-shadow var(--transition);
    box-shadow: 0 4px 20px rgba(26, 171, 152, 0.35);
  }

  .btn-primary:hover {
    background: var(--teal-d);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(26, 171, 152, 0.45);
  }

  .btn-outline {
    background: transparent;
    color: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.25);
    padding: 0.85rem 1.8rem;
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all var(--transition);
  }

  .btn-outline:hover {
    border-color: var(--teal);
    color: var(--teal);
    background: rgba(26, 171, 152, 0.08);
  }

  .hero-stats {
    display: flex;
    gap: 2rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    animation: fadeUp 0.7s 0.4s ease both;
  }

  

  .stat-num {
    font-family: var(--font-head);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1;
  }

  .stat-num span {
    color: var(--teal);
  }

  .stat-label {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 400;
    margin-top: 3px;
    letter-spacing: 0.04em;
  }

  /* Hero visual panel */
  .hero-visual {
    position: relative;
    animation: fadeUp 0.8s 0.25s ease both;
  }

  .hero-card-stack {
    position: relative;
  }

  .hero-main-card {
    background: rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
  }

  .hero-img-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    background: linear-gradient(145deg, rgba(26, 171, 152, 0.15), rgba(26, 39, 68, 0.3));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    position: relative;
    overflow: hidden;
  }

  .hero-img-placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 30% 40%, rgba(26, 171, 152, 0.2) 0%, transparent 50%),
      radial-gradient(circle at 70% 70%, rgba(198, 153, 58, 0.1) 0%, transparent 50%);
  }

  .upload-prompt {
    position: relative;
    text-align: center;
    color: rgba(255, 255, 255, 0.5);
  }

  .upload-icon {
    width: 56px;
    height: 56px;
    background: rgba(26, 171, 152, 0.2);
    border: 2px dashed rgba(26, 171, 152, 0.4);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 12px;
  }

  .upload-icon svg {
    width: 24px;
    height: 24px;
    stroke: var(--teal);
    fill: none;
    stroke-width: 1.8;
  }

  .upload-prompt p {
    font-size: 0.85rem;
    font-weight: 400;
    line-height: 1.4;
  }

  .upload-prompt strong {
    color: var(--teal);
    font-weight: 500;
  }

  .hero-img-label {
    padding: 1rem 1.2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .hero-img-label-dot {
    width: 8px;
    height: 8px;
    background: var(--teal);
    border-radius: 50%;
  }

  .hero-img-label-text {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 400;
  }

  /* Float badge on card */
  .hero-float-badge {
    position: absolute;
    top: -14px;
    right: 24px;
    background: var(--gold);
    color: var(--white);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 0.3rem 0.9rem;
    border-radius: 99px;
    box-shadow: var(--shadow);
  }

  .hero-modalities-mini {
    display: flex;
    gap: 8px;
    margin-top: 12px;
    flex-wrap: wrap;
  }

  .mini-tag {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 99px;
    padding: 0.28rem 0.8rem;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.65);
    font-weight: 400;
  }

  /* ── SECTION WRAPPER ── */
  .section {
    padding: 5rem 2rem;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--teal);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
  }

  .section-label::before {
    content: '';
    width: 22px;
    height: 2px;
    background: var(--teal);
    border-radius: 2px;
  }

  .section-h2 {
    font-family: var(--font-head);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 700;
    color: var(--navy);
    line-height: 1.2;
    margin-bottom: 0.8rem;
  }

  .section-h2 em {
    font-style: italic;
    color: var(--teal);
  }

  .section-sub {
    font-size: 1rem;
    color: var(--text-lt);
    max-width: 600px;
    font-weight: 300;
    line-height: 1.7;
  }

  /* ── MODALITIES SECTION ── */
  .modalities-bg {
    background: var(--white);
  }

  .modalities-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .modality-card {
    background: var(--off-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.8rem;
    position: relative;
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
    cursor: default;
  }

  .modality-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--teal), var(--teal-d));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition);
  }

  .modality-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(26, 171, 152, 0.2);
  }

  .modality-card:hover::before {
    transform: scaleX(1);
  }

  .modality-icon {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, var(--teal), var(--teal-d));
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.2rem;
    box-shadow: 0 4px 16px rgba(26, 171, 152, 0.25);
  }

  .modality-icon svg {
    width: 24px;
    height: 24px;
    stroke: var(--white);
    fill: none;
    stroke-width: 1.7;
  }

  .modality-title {
    font-family: var(--font-head);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 0.5rem;
  }

  .modality-desc {
    font-size: 0.88rem;
    color: var(--text-lt);
    line-height: 1.65;
  }

  .modality-tag {
    display: inline-block;
    margin-top: 1rem;
    background: rgba(26, 171, 152, 0.1);
    color: var(--teal-d);
    border-radius: 99px;
    padding: 0.2rem 0.75rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* ── MOBILISATION SECTION ── */
  .mobil-section {
    background: linear-gradient(160deg, var(--navy) 0%, var(--navy-d) 100%);
    position: relative;
    overflow: hidden;
  }

  .mobil-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 70% at 90% 30%, rgba(26, 171, 152, 0.12) 0%, transparent 65%);
    pointer-events: none;
  }

  .mobil-section .section-h2 {
    color: var(--white);
  }

  .mobil-section .section-sub {
    color: rgba(255, 255, 255, 0.6);
  }

  .mobil-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 3rem;
  }

  .mobil-card {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: background var(--transition), transform var(--transition);
  }

  .mobil-card:hover {
    background: rgba(255, 255, 255, 0.09);
    transform: translateY(-3px);
  }

  .mobil-card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 1.4rem;
  }

  .mobil-card-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mobil-card-icon.active {
    background: rgba(26, 171, 152, 0.2);
    border: 1px solid rgba(26, 171, 152, 0.3);
  }

  .mobil-card-icon.passive {
    background: rgba(198, 153, 58, 0.2);
    border: 1px solid rgba(198, 153, 58, 0.3);
  }

  .mobil-card-icon svg {
    width: 22px;
    height: 22px;
    stroke-width: 1.8;
    stroke: var(--teal);
    fill: none;
  }

  .mobil-card-icon.passive svg {
    stroke: var(--gold);
  }

  .mobil-card-title {
    font-family: var(--font-head);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--white);
  }

  .mobil-card-subtitle {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.45);
    font-weight: 300;
    margin-top: 1px;
  }

  .mobil-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .mobil-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.5;
  }

  .mobil-list li::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--teal);
    border-radius: 50%;
    margin-top: 7px;
    flex-shrink: 0;
  }

  .mobil-card:last-child .mobil-list li::before {
    background: var(--gold);
  }

  /* ── REHAB SECTION ── */
  .rehab-section {
    background: var(--off-white);
  }

  .rehab-intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    margin-top: 3rem;
    margin-bottom: 3rem;
  }

  .rehab-conditions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .condition-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 1.2rem 1.4rem;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .condition-item:hover {
    border-color: rgba(26, 171, 152, 0.3);
    box-shadow: var(--shadow);
  }

  .condition-num {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, var(--teal), var(--teal-d));
    color: var(--white);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .condition-text strong {
    display: block;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 2px;
  }

  .condition-text span {
    font-size: 0.82rem;
    color: var(--text-lt);
    font-weight: 300;
  }

  .rehab-highlight {
    background: var(--navy);
    border-radius: var(--radius-lg);
    padding: 2.4rem;
    color: var(--white);
    position: sticky;
    top: 88px;
  }

  .rehab-highlight h3 {
    font-family: var(--font-head);
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .rehab-highlight p {
    font-size: 0.87rem;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 300;
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }

  .rehab-benefits {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .benefit-row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.75);
    font-weight: 300;
  }

  .benefit-row svg {
    width: 16px;
    height: 16px;
    stroke: var(--teal);
    fill: none;
    stroke-width: 2;
    flex-shrink: 0;
  }

  .divider-gold {
    height: 2px;
    background: linear-gradient(90deg, var(--gold), transparent);
    border-radius: 2px;
    margin: 1.4rem 0;
  }

  /* ── IMAGE GALLERY ── */
  .gallery-section {
    background: var(--white);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    gap: 1rem;
    margin-top: 3rem;
  }

  .gallery-item {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--gray-lt);
    aspect-ratio: 4/3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 2px dashed var(--border);
    cursor: pointer;
    transition: border-color var(--transition), background var(--transition);
  }

  .gallery-item:hover {
    border-color: var(--teal);
    background: rgba(26, 171, 152, 0.04);
  }

  .gallery-item.featured {
    grid-column: span 2;
    aspect-ratio: 16/9;
  }

  .gallery-placeholder-icon {
    width: 40px;
    height: 40px;
    background: rgba(26, 171, 152, 0.12);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
  }

  .gallery-placeholder-icon svg {
    width: 20px;
    height: 20px;
    stroke: var(--teal);
    fill: none;
    stroke-width: 1.8;
  }

  .gallery-placeholder-text {
    font-size: 0.78rem;
    color: var(--gray);
    text-align: center;
    line-height: 1.4;
    padding: 0 1rem;
  }

  .gallery-placeholder-text strong {
    color: var(--teal);
    font-weight: 500;
    display: block;
  }

  .gallery-label {
    position: absolute;
    bottom: 10px;
    left: 10px;
    background: rgba(26, 39, 68, 0.75);
    backdrop-filter: blur(6px);
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.7rem;
    padding: 0.2rem 0.65rem;
    border-radius: 99px;
  }

  /* ── PROCESS SECTION ── */
  .process-section {
    background: var(--navy-d);
    position: relative;
    overflow: hidden;
  }

  .process-section::before {
    content: '';
    position: absolute;
    top: -100px;
    right: -100px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(26, 171, 152, 0.08) 0%, transparent 70%);
  }

  .process-section .section-h2 {
    color: var(--white);
  }

  .process-section .section-sub {
    color: rgba(255, 255, 255, 0.55);
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 3.5rem;
    position: relative;
  }

  .process-steps::before {
    content: '';
    position: absolute;
    top: 28px;
    left: calc(12.5% + 12px);
    right: calc(12.5% + 12px);
    height: 1px;
    background: linear-gradient(90deg, var(--teal), rgba(26, 171, 152, 0.2), var(--teal));
  }

  .process-step {
    text-align: center;
    position: relative;
  }

  .step-circle {
    width: 56px;
    height: 56px;
    background: rgba(26, 171, 152, 0.15);
    border: 2px solid var(--teal);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.2rem;
    position: relative;
    z-index: 1;
    transition: background var(--transition);
  }

  .process-step:hover .step-circle {
    background: rgba(26, 171, 152, 0.3);
  }

  .step-circle svg {
    width: 22px;
    height: 22px;
    stroke: var(--teal);
    fill: none;
    stroke-width: 1.8;
  }

  .step-num {
    position: absolute;
    top: -6px;
    right: -6px;
    width: 20px;
    height: 20px;
    background: var(--teal);
    color: var(--white);
    border-radius: 50%;
    font-size: 0.65rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .step-title {
    font-family: var(--font-head);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 0.4rem;
  }

  .step-desc {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 300;
    line-height: 1.5;
  }

  /* ── CTA SECTION ── */
  .cta-section {
    background: var(--off-white);
    padding: 5rem 2rem;
  }

  .cta-inner {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-box {
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-d) 100%);
    border-radius: var(--radius-lg);
    padding: 4rem 3rem;
    position: relative;
    overflow: hidden;
  }

  .cta-box::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(26, 171, 152, 0.18) 0%, transparent 60%);
  }

  .cta-box h2 {
    font-family: var(--font-head);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.8rem;
    position: relative;
  }

  .cta-box p {
    color: rgba(255, 255, 255, 0.6);
    font-size: 1rem;
    font-weight: 300;
    margin-bottom: 2rem;
    position: relative;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    position: relative;
  }

  .cta-contact-info {
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.85rem;
    font-weight: 300;
  }

  .contact-item svg {
    width: 16px;
    height: 16px;
    stroke: var(--teal);
    fill: none;
    stroke-width: 2;
  }

  /* ── FOOTER ── */
  footer {
    background: var(--navy-d);
    color: rgba(255, 255, 255, 0.45);
    padding: 2rem;
    text-align: center;
    font-size: 0.8rem;
    font-weight: 300;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  footer strong {
    color: var(--teal);
    font-weight: 500;
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero-visual {
      display: none;
    }

    .mobil-grid {
      grid-template-columns: 1fr;
    }

    .rehab-intro-grid {
      grid-template-columns: 1fr;
    }

    .rehab-highlight {
      position: relative;
      top: 0;
    }

    .process-steps {
      grid-template-columns: 1fr 1fr;
    }

    .process-steps::before {
      display: none;
    }

    .gallery-grid {
      grid-template-columns: 1fr 1fr;
    }

    .gallery-item.featured {
      grid-column: span 2;
    }

    .nav-links {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .section {
      padding: 3.5rem 1.2rem;
    }

    .hero {
      padding: 5rem 1.2rem 3rem;
    }

    nav {
      padding: 0 1.2rem;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .gallery-item.featured {
      grid-column: span 1;
    }

    .process-steps {
      grid-template-columns: 1fr;
    }

    .cta-box {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
</head>

