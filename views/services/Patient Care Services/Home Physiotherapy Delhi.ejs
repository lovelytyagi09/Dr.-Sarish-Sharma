<%- include('../../partials/boilerplate') %>
<%- include('../../partials/navbar') %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,500;0,600;0,700;1,400;1,600&family=Figtree:wght@300;400;500;600&display=swap');

  :root {
    --navy: #1A2744;
    --navy-d: #0F1A30;
    --teal: #1AAB98;
    --teal-d: #148A79;
    --gold: #C6993A;
    --white: #ffffff;
    --off-white: #F5F4EF;
    --gray-lt: #ECEDF2;
    --gray: #8A97AB;
    --gray-dk: #3F5264;
    --text: #171F2D;
    --text-lt: #4A5F75;
    --border: #DDE2EC;
    --font-head: 'Fraunces', Georgia, serif;
    --font-body: 'Figtree', sans-serif;
    --radius-sm: 6px;
    --radius: 14px;
    --radius-lg: 22px;
    --shadow-sm: 0 2px 8px rgba(15,26,48,0.06);
    --shadow: 0 4px 24px rgba(15,26,48,0.09);
    --shadow-lg: 0 12px 48px rgba(15,26,48,0.13);
    --transition: 0.25s ease;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0 }
  body { font-family: var(--font-body); color: var(--text); background: var(--white); overflow-x: hidden; line-height: 1.7 }
  img { max-width: 100%; display: block }
  a { text-decoration: none; color: inherit }

  /* ── HERO ── */
  .page-hero {
    background: linear-gradient(135deg, var(--navy-d) 0%, var(--navy) 100%);
    padding: 72px 5% 0; position: relative; overflow: hidden;
  }
  .page-hero::before {
    content: ''; position: absolute; inset: 0;
    background: repeating-linear-gradient(-55deg,
      transparent 0px, transparent 18px,
      rgba(255,255,255,0.018) 18px, rgba(255,255,255,0.018) 20px);
  }
  .page-hero::after {
    content: ''; position: absolute; top: -100px; right: -100px;
    width: 420px; height: 420px;
    background: radial-gradient(circle, rgba(26,171,152,0.16) 0%, transparent 65%);
    pointer-events: none;
  }
  .hero-grid {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 440px;
    gap: 56px; align-items: flex-end; position: relative; z-index: 1;
  }
  .hero-content { padding-bottom: 56px }

  .breadcrumb { display: flex; align-items: center; gap: 8px; margin-bottom: 20px; flex-wrap: wrap }
  .breadcrumb a { font-size: 0.78rem; color: rgba(255,255,255,0.48); transition: color var(--transition) }
  .breadcrumb a:hover { color: var(--gold) }
  .breadcrumb span { font-size: 0.78rem; color: rgba(255,255,255,0.22) }
  .breadcrumb .current { color: var(--gold); font-weight: 500 }

  .section-label {
    font-size: 0.70rem; font-weight: 600; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 14px;
    display: flex; align-items: center; gap: 10px;
  }
  .section-label::before { content: ''; width: 28px; height: 2px; background: var(--teal); border-radius: 2px; display: inline-block }

  .page-hero h1 {
    font-family: var(--font-head);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 600; color: var(--white);
    line-height: 1.18; letter-spacing: -0.02em; margin-bottom: 18px;
  }
  .page-hero h1 em { color: var(--gold); font-style: italic }
  .hero-desc { font-size: 1rem; color: rgba(255,255,255,0.58); line-height: 1.80; max-width: 520px; margin-bottom: 32px }

  .hero-badges { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 36px }
  .hero-badge-pill {
    display: inline-flex; align-items: center; gap: 7px;
    background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.14);
    color: rgba(255,255,255,0.78); font-size: 0.78rem; font-weight: 500;
    padding: 6px 14px; border-radius: 50px;
  }
  .hero-badge-pill i { color: var(--teal); font-size: 0.70rem }
  .hero-actions { display: flex; gap: 14px; flex-wrap: wrap }

  .btn-primary {
    background: var(--teal); color: var(--white); padding: 13px 28px; border-radius: 50px;
    font-family: var(--font-body); font-size: 0.88rem; font-weight: 600;
    display: inline-flex; align-items: center; gap: 9px;
    transition: all var(--transition); border: none; cursor: pointer;
  }
  .btn-primary:hover { background: var(--teal-d); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(26,171,152,0.32); color: var(--white) }
  .btn-ghost {
    background: transparent; color: var(--white); padding: 12px 26px; border-radius: 50px;
    font-family: var(--font-body); font-size: 0.88rem; font-weight: 600;
    display: inline-flex; align-items: center; gap: 9px;
    border: 1.5px solid rgba(255,255,255,0.28); transition: all var(--transition);
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.55); color: var(--white) }

  /* Hero image stack */
  .hero-imgs { position: relative; align-self: flex-end; height: 400px }
  .hero-img-main {
    position: absolute; bottom: 0; right: 0;
    width: 88%; height: 380px;
    object-fit: cover;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    box-shadow: 0 -10px 56px rgba(0,0,0,0.26);
  }
  .hero-img-badge {
    position: absolute; top: 20px; left: 0;
    background: var(--white); border-radius: var(--radius);
    padding: 14px 18px; box-shadow: var(--shadow-lg); text-align: center; min-width: 120px;
  }
  .hero-img-badge-num { font-family: var(--font-head); font-size: 1.6rem; font-weight: 700; color: var(--teal); line-height: 1 }
  .hero-img-badge-label { font-size: 0.64rem; color: var(--text-lt); margin-top: 4px; line-height: 1.4 }

  /* ── MODALITIES STRIP ── */
  .modalities-strip { background: var(--teal) }
  .modalities-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 0;
  }
  .modality-item {
    display: flex; flex-direction: column; align-items: center; text-align: center;
    gap: 10px; padding: 22px 12px;
    border-right: 1px solid rgba(255,255,255,0.18);
    transition: background var(--transition);
  }
  .modality-item:last-child { border-right: none }
  .modality-item:hover { background: rgba(255,255,255,0.08) }
  .modality-icon { width: 42px; height: 42px; background: rgba(255,255,255,0.16); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center }
  .modality-icon i { color: var(--white); font-size: 0.95rem }
  .modality-item strong { font-size: 0.80rem; font-weight: 700; color: var(--white) }
  .modality-item span { font-size: 0.68rem; color: rgba(255,255,255,0.65); line-height: 1.35 }

  /* ── MAIN CONTENT ── */
  .page-main { padding: 80px 5%; background: var(--white) }
  .page-main-grid { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 340px; gap: 56px; align-items: flex-start }

  .content-section { margin-bottom: 52px }
  .content-section:last-child { margin-bottom: 0 }
  .content-label {
    font-size: 0.70rem; font-weight: 700; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--teal); margin-bottom: 10px;
    display: flex; align-items: center; gap: 8px;
  }
  .content-label::before { content: ''; width: 20px; height: 2px; background: var(--gold); display: inline-block; border-radius: 2px }
  .content-h2 { font-family: var(--font-head); font-size: clamp(1.5rem, 2.5vw, 2rem); color: var(--navy); font-weight: 600; margin-bottom: 16px; letter-spacing: -0.02em; line-height: 1.3 }
  .content-h2 em { color: var(--teal); font-style: italic }
  .content-p { font-size: 0.95rem; color: var(--text-lt); line-height: 1.82; margin-bottom: 16px }
  .content-p:last-child { margin-bottom: 0 }
  .content-p strong { color: var(--navy) }

  /* ── 5 MODALITY CARDS ── */
  .modality-cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-top: 24px }
  .modality-card {
    background: var(--off-white); border: 1.5px solid var(--border);
    border-radius: var(--radius-lg); padding: 22px 20px;
    position: relative; overflow: hidden; transition: all var(--transition);
  }
  .modality-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; border-radius: 4px 4px 0 0 }
  .modality-card.swd::before   { background: var(--teal) }
  .modality-card.us::before    { background: var(--gold) }
  .modality-card.ir::before    { background: #e24b4a }
  .modality-card.laser::before { background: #8b65c8 }
  .modality-card.mob::before   { background: #34a8ea }
  .modality-card:hover { box-shadow: var(--shadow); transform: translateY(-4px); border-color: var(--teal) }
  .modality-card-icon { width: 42px; height: 42px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; margin-bottom: 12px }
  .modality-card.swd .modality-card-icon   { background: rgba(26,171,152,0.10); color: var(--teal) }
  .modality-card.us .modality-card-icon    { background: rgba(198,153,58,0.10); color: var(--gold) }
  .modality-card.ir .modality-card-icon    { background: rgba(226,75,74,0.10); color: #e24b4a }
  .modality-card.laser .modality-card-icon { background: rgba(139,101,200,0.10); color: #8b65c8 }
  .modality-card.mob .modality-card-icon   { background: rgba(52,168,234,0.10); color: #34a8ea }
  .modality-card-icon i { font-size: 0.95rem }
  .modality-card-num { font-family: var(--font-head); font-size: 3rem; font-weight: 700; color: rgba(26,39,68,0.04); position: absolute; top: 8px; right: 14px; line-height: 1 }
  .modality-card h4 { font-family: var(--font-head); font-size: 1rem; color: var(--navy); font-weight: 700; margin-bottom: 8px }
  .modality-card p { font-size: 0.82rem; color: var(--text-lt); line-height: 1.68 }
  .modality-cards .modality-card:last-child:nth-child(odd) { grid-column: 1 / -1 }

  /* ── REHAB SECTION ── */
  .rehab-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-top: 24px }
  .rehab-card {
    background: var(--navy); border-radius: var(--radius-lg);
    padding: 24px 20px; position: relative; overflow: hidden; transition: all var(--transition);
  }
  .rehab-card::before { content: ''; position: absolute; top: -30px; right: -30px; width: 100px; height: 100px; background: radial-gradient(circle, rgba(26,171,152,0.20) 0%, transparent 65%) }
  .rehab-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(15,26,48,0.22) }
  .rehab-card-icon { width: 44px; height: 44px; background: rgba(26,171,152,0.18); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; margin-bottom: 14px; border: 1px solid rgba(26,171,152,0.28) }
  .rehab-card-icon i { color: var(--teal); font-size: 1rem }
  .rehab-card h4 { font-family: var(--font-head); font-size: 1rem; color: var(--white); font-weight: 700; margin-bottom: 8px }
  .rehab-card p { font-size: 0.82rem; color: rgba(255,255,255,0.55); line-height: 1.68 }

  /* ── CHECKLIST ── */
  .check-list { display: flex; flex-direction: column; gap: 10px; margin-top: 20px }
  .check-item { display: flex; align-items: flex-start; gap: 12px; padding: 13px 16px; background: var(--off-white); border-radius: var(--radius-sm); border: 1px solid var(--border) }
  .check-item i { color: var(--teal); margin-top: 2px; flex-shrink: 0 }
  .check-item span { font-size: 0.87rem; color: var(--text); line-height: 1.5 }
  .check-item span strong { color: var(--navy) }

  /* ── EQUIPMENT GALLERY ── */
  .equipment-section { padding: 80px 5%; background: var(--off-white); border-top: 1px solid var(--border) }
  .equipment-inner { max-width: 1100px; margin: 0 auto }
  .equipment-head { text-align: center; margin-bottom: 48px }
  .equipment-head h2 { font-family: var(--font-head); font-size: clamp(1.6rem, 2.8vw, 2.2rem); color: var(--navy); font-weight: 600; letter-spacing: -0.02em; margin-bottom: 10px }
  .equipment-head h2 em { color: var(--teal); font-style: italic }
  .equipment-head p { font-size: 0.92rem; color: var(--text-lt); max-width: 480px; margin: 0 auto }

  .equipment-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 220px 220px;
    gap: 14px;
  }
  .equipment-item {
    position: relative; overflow: hidden;
    border-radius: var(--radius-lg); cursor: pointer;
    box-shadow: var(--shadow-sm); transition: all var(--transition);
  }
  .equipment-item:first-child { grid-column: 1; grid-row: 1 / 3 }
  .equipment-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; display: block }
  .equipment-item:hover img { transform: scale(1.07) }
  .equipment-item:hover { box-shadow: var(--shadow) }
  .equipment-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(15,26,48,0.65) 0%, transparent 55%);
    opacity: 0; transition: opacity var(--transition);
    display: flex; align-items: flex-end; padding: 18px;
  }
  .equipment-item:hover .equipment-overlay { opacity: 1 }
  .equipment-overlay span { font-size: 0.82rem; font-weight: 600; color: var(--white) }
  .equip-tag {
    position: absolute; top: 10px; left: 10px;
    background: rgba(255,255,255,0.92); color: var(--navy);
    font-size: 0.63rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    padding: 3px 10px; border-radius: 50px; backdrop-filter: blur(4px);
  }

  /* ── HOW IT WORKS ── */
  .how-section { padding: 80px 5%; background: var(--white) }
  .how-inner { max-width: 1100px; margin: 0 auto }
  .how-head { text-align: center; margin-bottom: 52px }
  .how-head h2 { font-family: var(--font-head); font-size: clamp(1.6rem, 2.8vw, 2.2rem); color: var(--navy); font-weight: 600; letter-spacing: -0.02em; margin-bottom: 10px }
  .how-head h2 em { color: var(--teal); font-style: italic }
  .how-head p { font-size: 0.92rem; color: var(--text-lt); max-width: 460px; margin: 0 auto }

  .how-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; position: relative }
  .how-steps::before {
    content: ''; position: absolute;
    top: 28px; left: 12.5%; right: 12.5%; height: 2px;
    background: linear-gradient(90deg, var(--teal), var(--gold));
    z-index: 0;
  }
  .how-step { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 0 16px; position: relative; z-index: 1 }
  .how-step-num {
    width: 56px; height: 56px; background: var(--navy); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-head); font-size: 1rem; font-weight: 700; color: var(--gold);
    margin-bottom: 20px; border: 4px solid var(--white);
    box-shadow: 0 0 0 2px var(--navy);
  }
  .how-step h4 { font-family: var(--font-head); font-size: 0.92rem; color: var(--navy); font-weight: 700; margin-bottom: 6px }
  .how-step p { font-size: 0.78rem; color: var(--text-lt); line-height: 1.60 }

  /* ── SIDEBAR ── */
  .sidebar { display: flex; flex-direction: column; gap: 20px }
  .sidebar-card { background: var(--off-white); border: 1.5px solid var(--border); border-radius: var(--radius-lg); padding: 26px 24px }
  .sidebar-card-title { font-family: var(--font-head); font-size: 1rem; color: var(--navy); font-weight: 700; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid var(--border); position: relative }
  .sidebar-card-title::after { content: ''; position: absolute; bottom: -1px; left: 0; width: 30px; height: 2px; background: var(--gold) }
  .appt-sidebar { background: linear-gradient(135deg, var(--navy-d) 0%, var(--navy) 100%); border-color: var(--navy) }
  .appt-sidebar .sidebar-card-title { color: var(--white); border-bottom-color: rgba(255,255,255,0.12) }
  .appt-sidebar p { font-size: 0.84rem; color: rgba(255,255,255,0.55); line-height: 1.65; margin-bottom: 20px }
  .appt-sidebar .btn-primary { width: 100%; justify-content: center; margin-bottom: 10px }
  .appt-sidebar .btn-call { width: 100%; display: flex; align-items: center; justify-content: center; gap: 9px; padding: 12px; border-radius: 50px; border: 1.5px solid rgba(255,255,255,0.22); color: var(--white); font-size: 0.85rem; font-weight: 600; transition: all var(--transition) }
  .appt-sidebar .btn-call:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.50) }
  .appt-sidebar .btn-call i { color: var(--teal); font-size: 0.80rem }
  .related-link { display: flex; align-items: center; gap: 12px; padding: 11px 0; border-bottom: 1px solid var(--border); transition: all var(--transition); font-size: 0.87rem; color: var(--text); font-weight: 500 }
  .related-link:last-child { border-bottom: none; padding-bottom: 0 }
  .related-link:hover { color: var(--teal); padding-left: 4px }
  .related-link i { color: var(--teal); font-size: 0.62rem; flex-shrink: 0 }
  .doc-card { display: flex; align-items: center; gap: 14px; margin-bottom: 16px }
  .doc-avatar { width: 56px; height: 56px; border-radius: 50%; object-fit: cover; object-position: top; flex-shrink: 0; border: 2px solid var(--teal) }
  .doc-name { font-family: var(--font-head); font-size: 0.95rem; font-weight: 700; color: var(--navy); margin-bottom: 2px }
  .doc-spec { font-size: 0.75rem; color: var(--teal) }
  .doc-creds { display: flex; flex-direction: column; gap: 6px }
  .doc-cred { display: flex; align-items: center; gap: 8px; font-size: 0.80rem; color: var(--text-lt) }
  .doc-cred i { color: var(--gold); font-size: 0.72rem; flex-shrink: 0 }

  /* ── CTA ── */
  .page-cta { background: linear-gradient(135deg, var(--navy-d) 0%, var(--navy) 100%); padding: 72px 5%; text-align: center; position: relative; overflow: hidden }
  .page-cta::before { content: ''; position: absolute; inset: 0; background: repeating-linear-gradient(-55deg, transparent 0px, transparent 18px, rgba(255,255,255,0.015) 18px, rgba(255,255,255,0.015) 20px) }
  .page-cta-inner { position: relative; z-index: 1 }
  .page-cta h2 { font-family: var(--font-head); font-size: clamp(1.6rem, 3vw, 2.4rem); color: var(--white); margin-bottom: 12px; font-weight: 600 }
  .page-cta h2 em { color: var(--gold); font-style: italic }
  .page-cta p { font-size: 0.98rem; color: rgba(255,255,255,0.55); max-width: 480px; margin: 0 auto 32px; line-height: 1.78 }
  .cta-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr }
    .hero-imgs { display: none }
    .page-main-grid { grid-template-columns: 1fr }
    .sidebar { flex-direction: row; flex-wrap: wrap }
    .sidebar-card { flex: 1; min-width: 280px }
    .modalities-inner { grid-template-columns: repeat(3, 1fr) }
    .modality-item:nth-child(3) { border-right: none }
    .how-steps { grid-template-columns: repeat(2, 1fr); gap: 32px }
    .how-steps::before { display: none }
    .equipment-gallery { grid-template-columns: repeat(2, 1fr); grid-template-rows: auto }
    .equipment-item:first-child { grid-column: auto; grid-row: auto }
  }
  @media (max-width: 640px) {
    .modalities-inner { grid-template-columns: repeat(2, 1fr) }
    .modality-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.15) }
    .modality-item:last-child { border-bottom: none }
    .modality-cards { grid-template-columns: 1fr }
    .rehab-grid { grid-template-columns: 1fr }
    .how-steps { grid-template-columns: 1fr }
    .equipment-gallery { grid-template-columns: 1fr }
    .cta-btns { flex-direction: column; align-items: center }
    .sidebar { flex-direction: column }
  }
</style>

<!-- ═══════ HERO ═══════ -->
<section class="page-hero">
  <div class="hero-grid">
    <div class="hero-content">
      <nav class="breadcrumb">
        <a href="/">Home</a><span>›</span>
        <a href="/services">Services</a><span>›</span>
        <span class="current">Home Physiotherapy Delhi</span>
      </nav>

      <div class="section-label">At-Home · Delhi NCR</div>
      <h1>Home <em>Physiotherapy</em> Delhi</h1>
      <p class="hero-desc">
        Professional physiotherapy brought directly to your home in Delhi — combining advanced electrotherapy modalities including Shortwave Diathermy, Ultrasonic, Hot Pads, Infrared, and Laser, along with hands-on mobilisation and personalised exercise programmes for faster recovery without leaving your house.
      </p>

      <div class="hero-badges">
        <span class="hero-badge-pill"><i class="fa-solid fa-house-medical"></i> At-Home Service</span>
        <span class="hero-badge-pill"><i class="fa-solid fa-bolt"></i> Electrotherapy Modalities</span>
        <span class="hero-badge-pill"><i class="fa-solid fa-person-walking"></i> Active & Passive Rehab</span>
      </div>

      <div class="hero-actions">
        <a href="/contact" class="btn-primary"><i class="fa-regular fa-calendar-check"></i> Book Home Visit</a>
        <a href="tel:+919560657964" class="btn-ghost"><i class="fa-solid fa-phone"></i> Call Now</a>
      </div>
    </div>

    <div class="hero-imgs">
      <img class="hero-img-main" src="/images/consult room.jpeg" alt="Home Physiotherapy Equipment Delhi" loading="eager">
      <div class="hero-img-badge">
        <div class="hero-img-badge-num">5+</div>
        <div class="hero-img-badge-label">Therapy<br>Modalities</div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════ MODALITIES STRIP ═══════ -->
<div class="modalities-strip">
  <div class="modalities-inner">
    <div class="modality-item">
      <div class="modality-icon"><i class="fa-solid fa-wave-square"></i></div>
