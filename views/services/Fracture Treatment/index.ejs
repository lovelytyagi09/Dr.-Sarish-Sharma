<%- include('../../partials/boilerplate') %>
<%- include('../../partials/navbar') %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,500;0,600;0,700;1,400;1,600&family=Figtree:wght@300;400;500;600&display=swap');

  :root {
    --navy: #1A2744;
    --navy-d: #0F1A30;
    --teal: #1AAB98;
    --teal-d: #148A79;
    --gold: #C6993A;
    --white: #ffffff;
    --off-white: #F5F4EF;
    --gray-lt: #ECEDF2;
    --gray: #8A97AB;
    --gray-dk: #3F5264;
    --text: #171F2D;
    --text-lt: #4A5F75;
    --border: #DDE2EC;
    --font-head: 'Fraunces', Georgia, serif;
    --font-body: 'Figtree', sans-serif;
    --radius-sm: 6px;
    --radius: 14px;
    --radius-lg: 22px;
    --shadow-sm: 0 2px 8px rgba(15,26,48,0.06);
    --shadow: 0 4px 24px rgba(15,26,48,0.09);
    --shadow-lg: 0 12px 48px rgba(15,26,48,0.13);
    --transition: 0.25s ease;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0 }
  body { font-family: var(--font-body); color: var(--text); background: var(--white); overflow-x: hidden; line-height: 1.7 }
  img { max-width: 100%; display: block }
  a { text-decoration: none; color: inherit }

  /* ── HERO ── */
  .service-hero {
    background: linear-gradient(135deg, var(--navy-d) 0%, var(--navy) 100%);
    padding: 72px 5% 0; position: relative; overflow: hidden;
  }
  .service-hero::before {
    content: ''; position: absolute; inset: 0;
    background: repeating-linear-gradient(-55deg,
      transparent 0px, transparent 18px,
      rgba(255,255,255,0.018) 18px, rgba(255,255,255,0.018) 20px);
  }
  .service-hero::after {
    content: ''; position: absolute; top: -100px; right: -100px;
    width: 420px; height: 420px;
    background: radial-gradient(circle, rgba(26,171,152,0.15) 0%, transparent 65%);
    pointer-events: none;
  }
  .service-hero-grid {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 420px;
    gap: 56px; align-items: flex-end; position: relative; z-index: 1;
  }
  .service-hero-content { padding-bottom: 56px }

  .breadcrumb { display: flex; align-items: center; gap: 8px; margin-bottom: 20px; flex-wrap: wrap }
  .breadcrumb a { font-size: 0.78rem; color: rgba(255,255,255,0.48); transition: color var(--transition) }
  .breadcrumb a:hover { color: var(--gold) }
  .breadcrumb span { font-size: 0.78rem; color: rgba(255,255,255,0.22) }
  .breadcrumb .current { color: var(--gold); font-weight: 500 }

  .section-label {
    font-size: 0.70rem; font-weight: 600; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--gold); margin-bottom: 14px;
    display: flex; align-items: center; gap: 10px;
  }
  .section-label::before { content: ''; width: 28px; height: 2px; background: var(--teal); border-radius: 2px; display: inline-block }

  .service-hero h1 {
    font-family: var(--font-head);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 600; color: var(--white);
    line-height: 1.18; letter-spacing: -0.02em; margin-bottom: 18px;
  }
  .service-hero h1 em { color: var(--gold); font-style: italic }
  .service-hero-desc { font-size: 1rem; color: rgba(255,255,255,0.58); line-height: 1.80; max-width: 520px; margin-bottom: 32px }

  .hero-badges { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 36px }
  .hero-badge-pill {
    display: inline-flex; align-items: center; gap: 7px;
    background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.14);
    color: rgba(255,255,255,0.78); font-size: 0.78rem; font-weight: 500;
    padding: 6px 14px; border-radius: 50px;
  }
  .hero-badge-pill i { color: var(--teal); font-size: 0.70rem }
  .hero-actions { display: flex; gap: 14px; flex-wrap: wrap }

  .btn-primary {
    background: var(--teal); color: var(--white); padding: 13px 28px; border-radius: 50px;
    font-family: var(--font-body); font-size: 0.88rem; font-weight: 600;
    display: inline-flex; align-items: center; gap: 9px;
    transition: all var(--transition); border: none; cursor: pointer;
  }
  .btn-primary:hover { background: var(--teal-d); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(26,171,152,0.32); color: var(--white) }
  .btn-ghost {
    background: transparent; color: var(--white); padding: 12px 26px; border-radius: 50px;
    font-family: var(--font-body); font-size: 0.88rem; font-weight: 600;
    display: inline-flex; align-items: center; gap: 9px;
    border: 1.5px solid rgba(255,255,255,0.28); transition: all var(--transition);
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.55); color: var(--white) }

  .service-hero-img-wrap { position: relative; align-self: flex-end }
  .service-hero-img { width: 100%; height: 400px; object-fit: cover; border-radius: var(--radius-lg) var(--radius-lg) 0 0; display: block; box-shadow: 0 -8px 48px rgba(0,0,0,0.28) }
  .hero-img-badge { position: absolute; top: 20px; left: -16px; background: var(--white); border-radius: var(--radius); padding: 14px 18px; box-shadow: var(--shadow-lg); text-align: center; min-width: 110px }
  .hero-img-badge-num { font-family: var(--font-head); font-size: 1.5rem; font-weight: 700; color: var(--teal); line-height: 1 }
  .hero-img-badge-label { font-size: 0.65rem; color: var(--text-lt); margin-top: 3px; line-height: 1.4 }

  /* ── 4 FRACTURE TYPES STRIP ── */
  .frac-strip { background: var(--navy) }
  .frac-strip-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 0;
  }
  .frac-type {
    display: flex; align-items: center; gap: 14px;
    padding: 24px 22px; border-right: 1px solid rgba(255,255,255,0.08);
    transition: background var(--transition);
  }
  .frac-type:last-child { border-right: none }
  .frac-type:hover { background: rgba(255,255,255,0.04) }
  .frac-type-icon { width: 44px; height: 44px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0 }
  .frac-type-icon.undis  { background: rgba(26,171,152,0.18) }
  .frac-type-icon.mildis { background: rgba(198,153,58,0.18) }
  .frac-type-icon.majdis { background: rgba(226,75,74,0.18) }
  .frac-type-icon.delayed { background: rgba(139,101,200,0.18) }
  .frac-type-icon.undis i   { color: var(--teal) }
  .frac-type-icon.mildis i  { color: var(--gold) }
  .frac-type-icon.majdis i  { color: #e24b4a }
  .frac-type-icon.delayed i { color: #8b65c8 }
  .frac-type-icon i { font-size: 1rem }
  .frac-type strong { display: block; font-size: 0.86rem; font-weight: 700; color: var(--white); margin-bottom: 2px }
  .frac-type span { font-size: 0.73rem; color: rgba(255,255,255,0.46) }

  /* ── QUICK FACTS ── */
  .quick-facts { background: var(--teal) }
  .quick-facts-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr) }
  .fact-item { display: flex; align-items: center; gap: 14px; padding: 22px 28px; border-right: 1px solid rgba(255,255,255,0.18) }
  .fact-item:last-child { border-right: none }
  .fact-icon { width: 40px; height: 40px; background: rgba(255,255,255,0.15); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0 }
  .fact-icon i { color: var(--white); font-size: 0.95rem }
  .fact-text strong { display: block; font-size: 0.85rem; font-weight: 700; color: var(--white); margin-bottom: 2px }
  .fact-text span { font-size: 0.74rem; color: rgba(255,255,255,0.70) }

  /* ── MAIN CONTENT ── */
  .service-main { padding: 80px 5%; background: var(--white) }
  .service-main-grid { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 340px; gap: 56px; align-items: flex-start }

  .content-section { margin-bottom: 52px }
  .content-section:last-child { margin-bottom: 0 }
  .content-label {
    font-size: 0.70rem; font-weight: 700; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--teal); margin-bottom: 10px;
    display: flex; align-items: center; gap: 8px;
  }
  .content-label::before { content: ''; width: 20px; height: 2px; background: var(--gold); display: inline-block; border-radius: 2px }
  .content-h2 { font-family: var(--font-head); font-size: clamp(1.5rem, 2.5vw, 2rem); color: var(--navy); font-weight: 600; margin-bottom: 16px; letter-spacing: -0.02em; line-height: 1.3 }
  .content-h2 em { color: var(--teal); font-style: italic }
  .content-p { font-size: 0.95rem; color: var(--text-lt); line-height: 1.82; margin-bottom: 16px }
  .content-p:last-child { margin-bottom: 0 }
  .content-p strong { color: var(--navy) }

  /* ── FRACTURE TYPE CARDS ── */
  .frac-cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-top: 24px }
  .frac-card {
    background: var(--off-white); border: 1.5px solid var(--border);
    border-radius: var(--radius-lg); padding: 24px 20px;
    position: relative; overflow: hidden; transition: all var(--transition);
  }
  .frac-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; border-radius: 4px 4px 0 0 }
  .frac-card.undis::before   { background: var(--teal) }
  .frac-card.mildis::before  { background: var(--gold) }
  .frac-card.majdis::before  { background: #e24b4a }
  .frac-card.delayed::before { background: #8b65c8 }
  .frac-card:hover { box-shadow: var(--shadow); transform: translateY(-4px); border-color: var(--teal) }
  .frac-card-num { font-family: var(--font-head); font-size: 3rem; font-weight: 700; color: rgba(26,39,68,0.04); position: absolute; top: 8px; right: 14px; line-height: 1 }
  .frac-card-icon { width: 42px; height: 42px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; margin-bottom: 14px }
  .frac-card.undis .frac-card-icon   { background: rgba(26,171,152,0.10); color: var(--teal) }
  .frac-card.mildis .frac-card-icon  { background: rgba(198,153,58,0.10); color: var(--gold) }
  .frac-card.majdis .frac-card-icon  { background: rgba(226,75,74,0.10); color: #e24b4a }
  .frac-card.delayed .frac-card-icon { background: rgba(139,101,200,0.10); color: #8b65c8 }
  .frac-card-icon i { font-size: 1rem }
  .frac-card h4 { font-family: var(--font-head); font-size: 1rem; color: var(--navy); font-weight: 700; margin-bottom: 8px }
  .frac-card p { font-size: 0.82rem; color: var(--text-lt); line-height: 1.68 }
  .frac-card ul { margin-top: 10px; padding-left: 0; list-style: none; display: flex; flex-direction: column; gap: 5px }
  .frac-card ul li { font-size: 0.79rem; color: var(--text-lt); display: flex; align-items: center; gap: 8px }
  .frac-card ul li::before { content: ''; width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0 }
  .frac-card.undis ul li::before   { background: var(--teal) }
  .frac-card.mildis ul li::before  { background: var(--gold) }
  .frac-card.majdis ul li::before  { background: #e24b4a }
  .frac-card.delayed ul li::before { background: #8b65c8 }

  /* ── IMMOBILISATION GRID ── */
  .immob-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 24px }
  .immob-item {
    background: var(--navy); border-radius: var(--radius);
    padding: 22px 14px; text-align: center;
    position: relative; overflow: hidden; transition: all var(--transition);
  }
  .immob-item::before { content: ''; position: absolute; top: -24px; right: -24px; width: 80px; height: 80px; background: radial-gradient(circle, rgba(26,171,152,0.22) 0%, transparent 65%) }
  .immob-item:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(15,26,48,0.22) }
  .immob-icon { width: 46px; height: 46px; background: rgba(26,171,152,0.18); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 12px; border: 1px solid rgba(26,171,152,0.28) }
  .immob-icon i { color: var(--teal); font-size: 1rem }
  .immob-item h4 { font-family: var(--font-head); font-size: 0.88rem; color: var(--white); font-weight: 700; margin-bottom: 5px }
  .immob-item p { font-size: 0.74rem; color: rgba(255,255,255,0.48); line-height: 1.55 }

  /* ── TREATMENT APPROACH CARDS ── */
  .approach-cards { display: flex; flex-direction: column; gap: 16px; margin-top: 24px }
  .approach-card {
    background: var(--white); border: 1.5px solid var(--border);
    border-radius: var(--radius-lg); padding: 24px 22px;
    display: grid; grid-template-columns: 52px 1fr; gap: 18px;
    align-items: flex-start; transition: all var(--transition);
    position: relative; overflow: hidden;
  }
  .approach-card::after { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: linear-gradient(to bottom, var(--teal), var(--gold)); transform: scaleY(0); transition: transform 0.35s ease }
  .approach-card:hover { box-shadow: var(--shadow); border-color: var(--teal); transform: translateX(4px) }
  .approach-card:hover::after { transform: scaleY(1) }
  .approach-icon { width: 52px; height: 52px; background: var(--navy); border-radius: var(--radius); display: flex; align-items: center; justify-content: center; flex-shrink: 0 }
  .approach-icon i { color: var(--gold); font-size: 1.1rem }
  .approach-tag { display: inline-flex; font-size: 0.67rem; font-weight: 700; letter-spacing: 0.10em; text-transform: uppercase; color: var(--teal); background: rgba(26,171,152,0.08); border: 1px solid rgba(26,171,152,0.18); padding: 3px 10px; border-radius: 50px; margin-bottom: 8px; width: fit-content }
  .approach-card h3 { font-family: var(--font-head); font-size: 1rem; color: var(--navy); font-weight: 700; margin-bottom: 8px }
  .approach-card p { font-size: 0.84rem; color: var(--text-lt); line-height: 1.72 }
  .approach-card p strong { color: var(--navy) }

  /* ── BMI HIGHLIGHT BOX ── */
  .bmi-highlight {
    background: linear-gradient(135deg, var(--navy-d) 0%, var(--navy) 100%);
    border-radius: var(--radius-lg); padding: 32px 28px; margin-top: 28px;
    position: relative; overflow: hidden;
  }
  .bmi-highlight::before {
    content: ''; position: absolute; top: -60px; right: -60px;
    width: 220px; height: 220px;
    background: radial-gradient(circle, rgba(26,171,152,0.20) 0%, transparent 65%);
    pointer-events: none;
  }
  .bmi-highlight-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 28px; align-items: center }
  .bmi-highlight-content {}
  .bmi-highlight-label { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gold); margin-bottom: 10px; display: flex; align-items: center; gap: 8px }
  .bmi-highlight-label::before { content: ''; width: 20px; height: 2px; background: var(--teal); display: inline-block; border-radius: 2px }
  .bmi-highlight h3 { font-family: var(--font-head); font-size: 1.4rem; color: var(--white); font-weight: 600; margin-bottom: 12px; line-height: 1.3 }
  .bmi-highlight h3 em { color: var(--gold); font-style: italic }
  .bmi-highlight p { font-size: 0.88rem; color: rgba(255,255,255,0.60); line-height: 1.75 }
  .bmi-stats { display: flex; flex-direction: column; gap: 14px }
  .bmi-stat { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10); border-radius: var(--radius); padding: 16px 18px; display: flex; align-items: center; gap: 14px }
  .bmi-stat-icon { width: 38px; height: 38px; background: rgba(26,171,152,0.18); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0 }
  .bmi-stat-icon i { color: var(--teal); font-size: 0.95rem }
  .bmi-stat-text strong { display: block; font-size: 0.88rem; font-weight: 700; color: var(--white); margin-bottom: 2px }
  .bmi-stat-text span { font-size: 0.75rem; color: rgba(255,255,255,0.48) }

  /* ── CHECKLIST ── */
  .check-list { display: flex; flex-direction: column; gap: 10px; margin-top: 20px }
  .check-item { display: flex; align-items: flex-start; gap: 12px; padding: 13px 16px; background: var(--off-white); border-radius: var(--radius-sm); border: 1px solid var(--border) }
  .check-item i { color: var(--teal); margin-top: 2px; flex-shrink: 0 }
  .check-item span { font-size: 0.87rem; color: var(--text); line-height: 1.5 }
  .check-item span strong { color: var(--navy) }

  /* ── WARNING BOX ── */
  .warning-box { background: rgba(226,75,74,0.05); border: 1.5px solid rgba(226,75,74,0.18); border-radius: var(--radius); padding: 20px 22px; margin-top: 20px; display: flex; gap: 14px; align-items: flex-start }
  .warning-box i { color: #e24b4a; font-size: 1.1rem; flex-shrink: 0; margin-top: 2px }
  .warning-box h4 { font-family: var(--font-head); font-size: 0.92rem; color: #c93535; font-weight: 700; margin-bottom: 6px }
  .warning-box p { font-size: 0.83rem; color: var(--text-lt); line-height: 1.65 }

  /* ── RECOVERY TIMELINE ── */
  .steps-grid { display: flex; flex-direction: column; gap: 0; margin-top: 20px; position: relative }
  .steps-grid::before { content: ''; position: absolute; left: 19px; top: 20px; bottom: 20px; width: 2px; background: linear-gradient(to bottom, var(--teal), rgba(26,171,152,0.08)) }
  .step-item { display: flex; gap: 20px; align-items: flex-start; padding: 18px 0; border-bottom: 1px solid var(--border); position: relative }
  .step-item:last-child { border-bottom: none }
  .step-num { width: 40px; height: 40px; background: var(--navy); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-family: var(--font-head); font-size: 0.88rem; font-weight: 700; color: var(--gold); border: 3px solid var(--white); box-shadow: 0 0 0 2px var(--navy); z-index: 1 }
  .step-body h4 { font-family: var(--font-head); font-size: 0.95rem; color: var(--navy); font-weight: 600; margin-bottom: 4px }
  .step-body p { font-size: 0.83rem; color: var(--text-lt); line-height: 1.65 }
  .step-badge { display: inline-block; font-size: 0.70rem; font-weight: 600; color: var(--teal-d); background: rgba(26,171,152,0.08); border: 1px solid rgba(26,171,152,0.18); padding: 2px 10px; border-radius: 50px; margin-bottom: 5px }

  /* ── FAQ ── */
  .faq-list { display: flex; flex-direction: column; gap: 10px; margin-top: 20px }
  .faq-item { background: var(--white); border: 1.5px solid var(--border); border-radius: var(--radius); overflow: hidden; transition: border-color var(--transition) }
  .faq-item:hover { border-color: var(--teal) }
  .faq-q { width: 100%; background: none; border: none; padding: 18px 20px; display: flex; align-items: center; justify-content: space-between; gap: 16px; cursor: pointer; text-align: left; font-family: var(--font-body); font-size: 0.9rem; font-weight: 600; color: var(--navy); transition: color var(--transition) }
  .faq-q:hover, .faq-q.open { color: var(--teal) }
  .faq-icon { width: 26px; height: 26px; background: var(--gray-lt); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--navy); font-size: 0.72rem; flex-shrink: 0; transition: all var(--transition) }
  .faq-q.open .faq-icon { background: var(--teal); color: var(--white); transform: rotate(45deg) }
  .faq-a { display: none; padding: 14px 20px 18px; font-size: 0.87rem; color: var(--text-lt); line-height: 1.75; border-top: 1px solid var(--border) }
  .faq-a.open { display: block }

  /* ── SIDEBAR ── */
  .sidebar { display: flex; flex-direction: column; gap: 20px }
  .sidebar-card { background: var(--off-white); border: 1.5px solid var(--border); border-radius: var(--radius-lg); padding: 26px 24px }
  .sidebar-card-title { font-family: var(--font-head); font-size: 1rem; color: var(--navy); font-weight: 700; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid var(--border); position: relative }
  .sidebar-card-title::after { content: ''; position: absolute; bottom: -1px; left: 0; width: 30px; height: 2px; background: var(--gold) }
  .appt-sidebar { background: linear-gradient(135deg, var(--navy-d) 0%, var(--navy) 100%); border-color: var(--navy) }
  .appt-sidebar .sidebar-card-title { color: var(--white); border-bottom-color: rgba(255,255,255,0.12) }
  .appt-sidebar p { font-size: 0.84rem; color: rgba(255,255,255,0.55); line-height: 1.65; margin-bottom: 20px }
  .appt-sidebar .btn-primary { width: 100%; justify-content: center; margin-bottom: 10px }
  .appt-sidebar .btn-call { width: 100%; display: flex; align-items: center; justify-content: center; gap: 9px; padding: 12px; border-radius: 50px; border: 1.5px solid rgba(255,255,255,0.22); color: var(--white); font-size: 0.85rem; font-weight: 600; transition: all var(--transition) }
  .appt-sidebar .btn-call:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.50) }
  .appt-sidebar .btn-call i { color: var(--teal); font-size: 0.80rem }
  .related-link { display: flex; align-items: center; gap: 12px; padding: 11px 0; border-bottom: 1px solid var(--border); transition: all var(--transition); font-size: 0.87rem; color: var(--text); font-weight: 500 }
  .related-link:last-child { border-bottom: none; padding-bottom: 0 }
  .related-link:hover { color: var(--teal); padding-left: 4px }
  .related-link i { color: var(--teal); font-size: 0.62rem; flex-shrink: 0 }
