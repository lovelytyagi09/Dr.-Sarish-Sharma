    <script>
      async function submitForm() {
        const btn = document.querySelector('.form-submit');

        const data = {
          firstName: document.querySelector('[name="firstName"]').value.trim(),
          lastName: document.querySelector('[name="lastName"]').value.trim(),
          phone: document.querySelector('[name="phone"]').value.trim(),
          email: document.querySelector('[name="email"]').value.trim(),
          date: document.querySelector('[name="date"]').value,
          time: document.querySelector('[name="time"]').value,
          service: document.querySelector('[name="service"]').value,
          concern: document.querySelector('[name="concern"]').value.trim(),
        };

        if (!data.firstName || !data.phone) {
          alert('Please fill in your name and phone number.');
          return;
        }

        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Opening WhatsApp...';
        btn.disabled = true;

        try {
          const response = await fetch('/submit-appointment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });

          const result = await response.json();
          window.open(result.url, '_blank');

          btn.innerHTML = '<i class="fa-solid fa-check"></i> Sent Successfully!';
          btn.style.background = '#16a34a';

        } catch (err) {
          alert('Something went wrong. Please try again.');
          btn.innerHTML = '<i class="fa-regular fa-calendar-check"></i> Confirm My Appointment';
          btn.disabled = false;
        }
      }
    </script>
