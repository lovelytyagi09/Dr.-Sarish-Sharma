<%- include('partials/boilerplate') %>
  <%- include('partials/navbar') %>


    <style>
    @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,500;0,600;0,700;1,400;1,600&family=Figtree:wght@300;400;500;600&display=swap');

:root {
  --navy:     #1A2744;
  --navy-d:   #0F1A30;
  --teal:     #1AAB98;
  --teal-d:   #148A79;
  --gold:     #C6993A;
  --white:    #ffffff;
  --off-white:#F5F4EF;
  --gray-lt:  #ECEDF2;
  --gray:     #8A97AB;
  --gray-dk:  #3F5264;
  --text:     #171F2D;
  --text-lt:  #4A5F75;
  --border:   #DDE2EC;
  --font-head:'Fraunces', Georgia, serif;
  --font-body:'Figtree', sans-serif;

    --radius-sm: 6px;
  --radius:    14px;
  --radius-lg: 22px;
  --shadow-sm: 0 2px 8px rgba(15, 26, 48, 0.06);
  --shadow:    0 4px 24px rgba(15, 26, 48, 0.09);
  --shadow-lg: 0 12px 48px rgba(15, 26, 48, 0.13);
  --transition: 0.25s ease;
}
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: var(--font-body);
        color: var(--text);
        background: var(--white);
        line-height: 1.7;
        overflow-x: hidden;
      }

      /* ── PAGE HEADER ── */
      .contact-hero {
        background: linear-gradient(135deg, var(--navy-d) 0%, var(--navy) 100%);
        padding: 72px 5% 64px;
        position: relative;
        overflow: hidden;
      }

      .contact-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(-55deg,
            transparent 0px, transparent 18px,
            rgba(255, 255, 255, 0.02) 18px, rgba(255, 255, 255, 0.02) 20px);
      }

      .contact-hero::after {
        content: '';
        position: absolute;
        top: -80px;
        right: -80px;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(27, 153, 139, 0.2) 0%, transparent 65%);
        pointer-events: none;
      }

      .contact-hero-inner {
        max-width: 700px;
        position: relative;
        z-index: 1;
      }

      .section-label {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .section-label::before {
        content: '';
        display: inline-block;
        width: 28px;
        height: 2px;
        background: var(--teal);
        border-radius: 2px;
      }

      .contact-hero h1 {
        font-family: var(--font-head);
        font-size: 2.8rem;
        font-weight: 700;
        color: var(--white);
        line-height: 1.2;
        letter-spacing: -0.02em;
        margin-bottom: 14px;
      }

      .contact-hero h1 em {
        color: var(--gold);
        font-style: italic;
      }

      .contact-hero p {
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.65);
        line-height: 1.75;
        max-width: 520px;
      }

      /* ── CONTACT CARDS ROW ── */
      .contact-cards-section {
        background: var(--off-white);
        padding: 56px 5%;
      }

      .contact-cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 18px;
        max-width: 1100px;
        margin: 0 auto;
      }

      .contact-card {
        background: var(--white);
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        padding: 28px 24px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        box-shadow: var(--shadow-sm);
        transition: box-shadow var(--transition), transform var(--transition), border-color var(--transition);
        text-decoration: none;
        color: inherit;
        position: relative;
        overflow: hidden;
      }

      .contact-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--teal), var(--gold));
        opacity: 0;
        transition: opacity var(--transition);
      }

      .contact-card:hover {
        box-shadow: var(--shadow);
        transform: translateY(-3px);
        border-color: var(--teal);
      }

      .contact-card:hover::before {
        opacity: 1;
      }

      .card-icon {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
      }

      .card-icon.teal {
        background: rgba(27, 153, 139, 0.1);
      }

      .card-icon.gold {
        background: rgba(201, 168, 76, 0.1);
      }

      .card-icon.green {
        background: rgba(37, 211, 102, 0.1);
      }

      .card-icon.navy {
        background: rgba(10, 35, 66, 0.08);
      }

      .card-label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--gray);
      }

      .card-value {
        font-family: var(--font-head);
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--navy);
        line-height: 1.3;
      }

      .card-sub {
        font-size: 0.8rem;
        color: var(--text-lt);
      }

      .whatsapp-card {
        background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
        border-color: #25D366;
        color: var(--white);
      }

      .whatsapp-card .card-label {
        color: rgba(255, 255, 255, 0.7);
      }

      .whatsapp-card .card-value {
        color: var(--white);
      }

      .whatsapp-card .card-sub {
        color: rgba(255, 255, 255, 0.7);
      }

      .whatsapp-card:hover {
        border-color: #25D366;
        transform: translateY(-3px);
      }

      .whatsapp-card::before {
        background: rgba(255, 255, 255, 0.15);
        opacity: 1;
      }

      .whatsapp-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, 0.2);
        color: var(--white);
        font-size: 0.75rem;
        font-weight: 600;
        padding: 4px 12px;
        border-radius: 50px;
        width: fit-content;
        margin-top: 4px;
      }

      .whatsapp-badge .dot {
        width: 7px;
        height: 7px;
        background: var(--white);
        border-radius: 50%;
      }

      /* ── MAIN CONTENT ── */
      .contact-main {
        padding: 72px 5%;
        background: var(--white);
      }

      .contact-main-grid {
        display: grid;
        grid-template-columns: 1fr 420px;
        gap: 56px;
        max-width: 1100px;
        margin: 0 auto;
      }

      /* ── FORM ── */
      .form-heading {
        font-family: var(--font-head);
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 28px;
        letter-spacing: -0.02em;
      }

      .form-heading em {
        color: var(--teal);
        font-style: italic;
      }

      .appt-form {
        display: flex;
        flex-direction: column;
        gap: 18px;
      }

      .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
      }

      .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      .form-group label {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--navy);
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .form-group input,
      .form-group select,
      .form-group textarea {
        padding: 12px 16px;
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        font-family: var(--font-body);
        font-size: 0.92rem;
        color: var(--text);
        background: var(--white);
        transition: border-color var(--transition), box-shadow var(--transition);
        outline: none;
        width: 100%;
      }

      .form-group input:focus,
      .form-group select:focus,
      .form-group textarea:focus {
        border-color: var(--teal);
        box-shadow: 0 0 0 3px rgba(27, 153, 139, 0.1);
      }

      .form-group textarea {
        resize: vertical;
        min-height: 110px;
      }

      .form-group select {
        appearance: none;
        cursor: pointer;
      }

      .btn-submit {
        background: var(--teal);
        color: var(--white);
        padding: 14px 32px;
        border: none;
        border-radius: 50px;
        font-family: var(--font-body);
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        cursor: pointer;
        transition: background var(--transition), transform var(--transition);
        box-shadow: 0 4px 16px rgba(27, 153, 139, 0.3);
        align-self: flex-start;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .btn-submit:hover {
        background: var(--teal-d);
        transform: translateY(-2px);
      }

      .form-note {
        font-size: 0.78rem;
        color: var(--text-lt);
        display: flex;
        align-items: center;
        gap: 6px;
      }

      /* ── RIGHT SIDE — OPD + ADDRESS ── */
      .right-col {
        display: flex;
        flex-direction: column;
        gap: 24px;
      }

      .opd-box {
        background: linear-gradient(135deg, var(--navy-d) 0%, var(--navy) 100%);
        border-radius: var(--radius-lg);
        padding: 28px 26px;
        position: relative;
        overflow: hidden;
      }

      .opd-box::before {
        content: '';
        position: absolute;
        top: -40px;
        right: -40px;
        width: 160px;
        height: 160px;
        background: radial-gradient(circle, rgba(27, 153, 139, 0.2) 0%, transparent 65%);
        pointer-events: none;
      }

      .opd-box-label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .opd-box-label::before {
        content: '';
        width: 20px;
        height: 2px;
        background: var(--teal);
        display: inline-block;
        border-radius: 2px;
      }

      .opd-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
      }

      .opd-row:last-child {
        border-bottom: none;
      }

      .opd-row .day {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.6);
      }

      .opd-row .time {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--white);
        text-align: right;
      }

      .opd-row .time.closed {
        color: rgba(255, 255, 255, 0.3);
        font-weight: 400;
      }

      .opd-emergency {
        margin-top: 16px;
        background: rgba(27, 153, 139, 0.15);
        border: 1px solid rgba(27, 153, 139, 0.3);
        border-radius: var(--radius-sm);
        padding: 10px 14px;
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.7);
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .opd-emergency strong {
        color: var(--white);
      }

      .address-box {
        background: var(--off-white);
        border: 1.5px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 26px;
        display: flex;
        flex-direction: column;
        gap: 16px;
      }

      .address-box-title {
        font-family: var(--font-head);
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--navy);
      }

      .address-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
      }

      .address-icon {
        width: 34px;
        height: 34px;
        flex-shrink: 0;
        background: var(--white);
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--teal);
        margin-top: 2px;
      }

      .address-detail strong {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--navy);
      }

      .address-detail span {
        font-size: 0.82rem;
        color: var(--text-lt);
        line-height: 1.5;
      }

      .metro-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(27, 153, 139, 0.08);
        border: 1px solid rgba(27, 153, 139, 0.2);
        color: var(--teal-d);
        font-size: 0.75rem;
        font-weight: 600;
        padding: 5px 12px;
        border-radius: 50px;
      }

      /* ── MAP ── */
      .map-section {
        padding: 0 5% 80px;
        background: var(--white);
      }

      .map-wrap {
        max-width: 1100px;
        margin: 0 auto;
      }

      .map-heading {
        font-family: var(--font-head);
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 20px;
        letter-spacing: -0.02em;
      }

      .map-frame {
        width: 100%;
        height: 420px;
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 1.5px solid var(--border);
        box-shadow: var(--shadow);
      }

      .map-frame iframe {
        width: 100%;
        height: 100%;
        border: none;
        display: block;
      }

      /* ── RESPONSIVE ── */
      @media (max-width: 900px) {
        .contact-main-grid {
          grid-template-columns: 1fr;
        }

        .contact-hero h1 {
          font-size: 2rem;
        }
      }

      @media (max-width: 600px) {
        .form-row {
          grid-template-columns: 1fr;
        }

        .contact-hero {
          padding: 52px 5% 44px;
        }

        .map-frame {
          height: 300px;
        }
      }
    </style>

    <!-- ═══════ PAGE HEADER ═══════ -->
    <section class="contact-hero">
      <div class="contact-hero-inner">
        <div class="section-label">Get in Touch</div>
        <h1>Book an <em>Appointment</em></h1>
