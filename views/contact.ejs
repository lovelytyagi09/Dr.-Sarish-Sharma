                  <circle cx="12" cy="10" r="3" />
                </svg>
              </div>
              <div class="address-detail">
                <strong>Clinic Address</strong>
                <span>Matri Mandir Rd, Block B 2, Safdarjung Enclave, New Delhi, Delhi 110029</span>
              </div>
            </div>
            <div class="address-row">
              <div class="address-icon">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <rect x="2" y="7" width="20" height="14" rx="2" />
                  <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" />
                </svg>
              </div>
              <div class="address-detail">
                <strong>Nearest Landmark</strong>
                <span>Matri Mandir Rd</span>
              </div>
            </div>
            <div class="address-row">
              <div class="address-icon">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path
                    d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
              </div>
              <div class="address-detail">
                <strong>Nearest Metro Station</strong>
                <span class="metro-tag">🚇 Bhikaji Cama Place Metro — Pink Line</span>
              </div>
