      </div>
    </section>

    <!-- ═══════ FORM + OPD + ADDRESS ═══════ -->
    <section class="contact-main">
      <div class="contact-main-grid">

        <!-- LEFT — Appointment Form -->
        <div class="appt-form fade-up fade-up-delay-2">
          <h3>Request an Appointment</h3>
          <p>We'll contact you to confirm your preferred slot within 2 hours.</p>

          <div class="form-row">
            <div class="form-group">
              <label>First Name</label>
              <input type="text" name="firstName" placeholder="Rajesh" />
            </div>
            <div class="form-group">
              <label>Last Name</label>
              <input type="text" name="lastName" placeholder="Kumar" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label>Phone Number</label>
              <input type="tel" name="phone" placeholder="+91 00000 00000" />
            </div>
            <div class="form-group">
              <label>Email Address</label>
              <input type="email" name="email" placeholder="you@example.com" />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label>Preferred Date</label>
              <input type="date" name="date" />
            </div>
            <div class="form-group">
              <label>Preferred Time</label>
              <select name="time">
                <option value="">Select a slot</option>
                <option>9:00 AM – 10:00 AM</option>
                <option>10:00 AM – 11:00 AM</option>
                <option>11:00 AM – 12:00 PM</option>
                <option>2:00 PM – 3:00 PM</option>
                <option>3:00 PM – 4:00 PM</option>
                <option>5:00 PM – 6:00 PM</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label>Service Required</label>
            <select name="service">
              <option value="">Select a treatment</option>
              <option>Pain Management</option>
              <option>PRP Therapy</option>
              <option>Joint Lubrication</option>
              <option>Nerve Block</option>
              <option>Disc Treatment</option>
              <option>ACL Reconstruction</option>
              <option>Knee / Hip / Spine Care</option>
              <option>Fracture Treatment (Delayed / Non-Union)</option>
              <option>Sports Injury</option>
              <option>Vitamin Balance Consultation</option>
              <option>General Orthopedic Consultation</option>
            </select>
          </div>

          <div class="form-group">
            <label>Describe Your Concern (Optional)</label>
            <textarea name="concern"
              placeholder="Tell us briefly about your pain, symptoms, or specific concern..."></textarea>
          </div>

          <button class="form-submit" type="button" onclick="submitForm()">
            <i class="fa-regular fa-calendar-check"></i> Confirm My Appointment
          </button>
          <p class="form-note">
            <i class="fa-solid fa-lock"></i>
            Your information is kept strictly confidential. We will call to confirm your appointment.
          </p>
        </div>

        <!-- RIGHT — OPD Timings + Address -->
        <div class="right-col">

          <!-- OPD Timings -->
          <div class="opd-box">
            <div class="opd-box-label">OPD Timings</div>
            <div class="opd-row">
