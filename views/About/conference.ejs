<style>
:root {
  --navy:      #1A2744;
  --navy-d:    #0F1A30;
  --teal:      #1AAB98;
  --teal-d:    #148A79;
  --gold:      #C6993A;
  --white:     #ffffff;
  --off-white: #F5F4EF;
  --gray-lt:   #ECEDF2;
  --gray:      #8A97AB;
  --gray-dk:   #3F5264;
  --text:      #171F2D;
  --text-lt:   #4A5F75;
  --border:    #DDE2EC;
  --font-head: 'Fraunces', Georgia, serif;
  --font-body: 'Figtree', sans-serif;
  --radius-sm: 6px;
  --radius:    14px;
  --radius-lg: 22px;
  --shadow-sm: 0 2px 8px rgba(15,26,48,0.06);
  --shadow:    0 4px 24px rgba(15,26,48,0.09);
  --shadow-lg: 0 12px 48px rgba(15,26,48,0.13);
  --transition:0.25s ease;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--off-white);
  color: var(--text);
  font-family: var(--font-body);
  font-weight: 400;
  line-height: 1.6;
  min-height: 100vh;
}

/* ── PAGE WRAPPER ── */
.page {
  max-width: 860px;
  margin: 0 auto;
  padding: 56px 24px 80px;
}

/* ── HEADER ── */
.section-header {
  display: flex;
  align-items: flex-end;
  gap: 20px;
  margin-bottom: 48px;
  animation: fadeUp 0.6s ease both;
}

.header-accent {
  width: 5px;
  height: 64px;
  background: linear-gradient(180deg, var(--teal) 0%, var(--gold) 100%);
  border-radius: 99px;
  flex-shrink: 0;
  margin-bottom: 4px;
}

.header-text h1 {
  font-family: var(--font-head);
  font-size: clamp(1.75rem, 4vw, 2.6rem);
  font-weight: 700;
  color: var(--navy-d);
  letter-spacing: -0.02em;
  line-height: 1.1;
}

.header-text p {
  font-family: var(--font-body);
  font-size: 0.9rem;
  color: var(--gray);
  font-weight: 400;
  margin-top: 4px;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

/* ── CATEGORY LABEL ── */
.category-label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 4px 12px;
  border-radius: 99px;
  margin-bottom: 18px;
}

.category-label.presentation {
  background: rgba(198,153,58,0.12);
  color: var(--gold);
}
.category-label.course {
  background: rgba(26,171,152,0.12);
  color: var(--teal-d);
}
.category-label.conference {
  background: rgba(26,39,68,0.09);
  color: var(--navy);
}
.category-label.workshop {
  background: rgba(63,82,100,0.1);
  color: var(--gray-dk);
}
.category-label.cme {
  background: rgba(26,171,152,0.08);
  color: var(--teal-d);
}

.category-label::before {
  content: '';
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: currentColor;
}

/* ── CARDS ── */
.cards {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.card {
  background: var(--white);
  border-radius: var(--radius-lg);
  border: 1px solid var(--border);
  padding: 28px 30px;
  box-shadow: var(--shadow-sm);
  transition: box-shadow var(--transition), transform var(--transition);
  position: relative;
  overflow: hidden;
  animation: fadeUp 0.5s ease both;
}

.card::before {
  content: '';
  position: absolute;
  inset: 0 auto 0 0;
  width: 4px;
  border-radius: 4px 0 0 4px;
  transition: width var(--transition);
}

.card.type-presentation::before { background: var(--gold); }
.card.type-course::before       { background: var(--teal); }
.card.type-conference::before   { background: var(--navy); }
.card.type-workshop::before     { background: var(--gray-dk); }
.card.type-cme::before          { background: var(--teal-d); }

.card:hover {
  box-shadow: var(--shadow);
  transform: translateY(-2px);
}
.card:hover::before { width: 6px; }

.card-inner {
  padding-left: 20px;
}

.card-title {
  font-family: var(--font-head);
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--navy-d);
  line-height: 1.3;
  margin-bottom: 10px;
  letter-spacing: -0.01em;
}

.card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 16px;
  align-items: center;
}

.meta-tag {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 0.8rem;
  color: var(--text-lt);
  font-weight: 400;
}

.meta-tag svg {
  opacity: 0.55;
  flex-shrink: 0;
}

.meta-tag.year {
  font-family: var(--font-head);
  font-style: italic;
  font-size: 0.85rem;
  color: var(--gray-dk);
  font-weight: 400;
}

/* ── QUOTE STYLE FOR PAPER ── */
.paper-quote {
  display: inline;
  font-style: italic;
  color: var(--gray-dk);
}

/* ── DIVIDER ── */
.section-divider {
  display: flex;
  align-items: center;
  gap: 14px;
  margin: 36px 0 24px;
  animation: fadeUp 0.5s ease both;
}

.section-divider span {
  font-family: var(--font-body);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gray);
  white-space: nowrap;
}

.divider-line {
  flex: 1;
  height: 1px;
  background: var(--border);
}

/* ── STATS STRIP ── */
.stats-strip {
  display: flex;
  gap: 0;
  background: var(--navy-d);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: 40px;
  box-shadow: var(--shadow);
  animation: fadeUp 0.5s 0.1s ease both;
}

.stat-item {
  flex: 1;
  padding: 22px 20px;
  text-align: center;
  position: relative;
}

.stat-item + .stat-item::before {
  content: '';
  position: absolute;
  left: 0; top: 20%; bottom: 20%;
  width: 1px;
  background: rgba(255,255,255,0.1);
}

.stat-num {
  font-family: var(--font-head);
  font-size: 1.9rem;
  font-weight: 700;
  color: var(--white);
  line-height: 1;
  margin-bottom: 4px;
}

.stat-num span {
  color: var(--teal);
}

.stat-label {
  font-size: 0.72rem;
  color: rgba(255,255,255,0.5);
  font-weight: 400;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

/* ── ANIMATION ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}

.card:nth-child(1) { animation-delay: 0.10s; }
.card:nth-child(2) { animation-delay: 0.18s; }
.card:nth-child(3) { animation-delay: 0.26s; }
.card:nth-child(4) { animation-delay: 0.34s; }
.card:nth-child(5) { animation-delay: 0.42s; }
.card:nth-child(6) { animation-delay: 0.50s; }

/* ── RESPONSIVE ── */
@media (max-width: 560px) {
  .page { padding: 36px 16px 60px; }
  .stats-strip { flex-direction: column; }
  .stat-item + .stat-item::before { left: 20%; right: 20%; top: 0; bottom: auto; width: auto; height: 1px; }
  .card { padding: 22px 20px; }
}
</style>

