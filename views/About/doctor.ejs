  <script>
    function toggleAcc(header) {
      const item = header.closest('[data-acc]');
      const isOpen = item.classList.contains('open');
      // Close all
      document.querySelectorAll('[data-acc]').forEach(i => i.classList.remove('open'));
      // If wasn't open, open it
      if (!isOpen) item.classList.add('open');
    }

    // Intersection observer for scroll animations
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.style.opacity = '1';
          e.target.style.transform = 'translateY(0)';
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('.stat-card, .opd-card, .diet-point, .acc-item').forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(18px)';
      el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
      obs.observe(el);
    });
    function toggleAbout(e) {
      e.stopPropagation();
      document.querySelector('.about-dropdown-wrapper').classList.toggle('open');
    }

    // Close when clicking outside
    document.addEventListener('click', function () {
      document.querySelector('.about-dropdown-wrapper').classList.remove('open');
    });

  </script>

