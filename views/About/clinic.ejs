<%- include('../partials/boilerplate') %>
    <%- include('../partials/navbar') %>

        <style>
            @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,500;0,600;0,700;1,400;1,600&family=Figtree:wght@300;400;500;600&display=swap');

            :root {
                --navy: #1A2744;
                --navy-d: #0F1A30;
                --teal: #1AAB98;
                --teal-d: #148A79;
                --gold: #C6993A;
                --white: #ffffff;
                --off-white: #F5F4EF;
                --gray-lt: #ECEDF2;
                --gray: #8A97AB;
                --gray-dk: #3F5264;
                --text: #171F2D;
                --text-lt: #4A5F75;
                --border: #DDE2EC;
                --font-head: 'Fraunces', Georgia, serif;
                --font-body: 'Figtree', sans-serif;
                --radius-sm: 6px;
                --radius: 14px;
                --radius-lg: 22px;
                --shadow-sm: 0 2px 8px rgba(15, 26, 48, 0.06);
                --shadow: 0 4px 24px rgba(15, 26, 48, 0.09);
                --shadow-lg: 0 12px 48px rgba(15, 26, 48, 0.13);
                --transition: 0.25s ease;
            }

            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0
            }

            body {
                font-family: var(--font-body);
                color: var(--text);
                background: var(--white);
                overflow-x: hidden;
                line-height: 1.7
            }

            img {
                max-width: 100%;
                display: block
            }

            a {
                text-decoration: none;
                color: inherit
            }

            /* ── HERO ── */
            .clinic-hero {
                background: linear-gradient(135deg, var(--navy-d) 0%, var(--navy) 100%);
                padding: 80px 5% 0;
                position: relative;
                overflow: hidden;
            }

            .clinic-hero::before {
                content: '';
                position: absolute;
                inset: 0;
                background: repeating-linear-gradient(-55deg,
                        transparent 0px, transparent 18px,
                        rgba(255, 255, 255, 0.018) 18px, rgba(255, 255, 255, 0.018) 20px);
            }

            .clinic-hero::after {
                content: '';
                position: absolute;
                top: -120px;
                right: -120px;
                width: 480px;
                height: 480px;
                background: radial-gradient(circle, rgba(26, 171, 152, 0.15) 0%, transparent 65%);
                pointer-events: none;
            }

            .clinic-hero-grid {
                max-width: 1100px;
                margin: 0 auto;
                display: grid;
                grid-template-columns: 1fr 480px;
                gap: 60px;
                align-items: flex-end;
                position: relative;
                z-index: 1;
            }

            .clinic-hero-content {
                padding-bottom: 64px
            }

            .breadcrumb {
                display: flex;
                align-items: center;
                gap: 8px;
                margin-bottom: 22px;
                flex-wrap: wrap
            }

            .breadcrumb a {
                font-size: 0.78rem;
                color: rgba(255, 255, 255, 0.48);
                transition: color var(--transition)
            }

            .breadcrumb a:hover {
                color: var(--gold)
            }

            .breadcrumb span {
                font-size: 0.78rem;
                color: rgba(255, 255, 255, 0.22)
            }

            .breadcrumb .current {
                color: var(--gold);
                font-weight: 500
            }

            .section-label {
                font-size: 0.70rem;
                font-weight: 600;
                letter-spacing: 0.18em;
                text-transform: uppercase;
                color: var(--gold);
                margin-bottom: 14px;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .section-label::before {
                content: '';
                width: 28px;
                height: 2px;
                background: var(--teal);
                border-radius: 2px;
                display: inline-block
            }

            .clinic-hero h1 {
                font-family: var(--font-head);
                font-size: clamp(2rem, 4vw, 3.2rem);
                font-weight: 600;
                color: var(--white);
                line-height: 1.18;
                letter-spacing: -0.02em;
                margin-bottom: 18px;
            }

            .clinic-hero h1 em {
                color: var(--gold);
                font-style: italic
            }

            .clinic-hero-desc {
                font-size: 1rem;
                color: rgba(255, 255, 255, 0.58);
                line-height: 1.80;
                max-width: 500px;
                margin-bottom: 36px
            }

            .hero-pills {
                display: flex;
                gap: 10px;
                flex-wrap: wrap;
                margin-bottom: 40px
            }

            .hero-pill {
                display: inline-flex;
                align-items: center;
                gap: 7px;
                background: rgba(255, 255, 255, 0.07);
                border: 1px solid rgba(255, 255, 255, 0.14);
                color: rgba(255, 255, 255, 0.78);
                font-size: 0.78rem;
                font-weight: 500;
                padding: 7px 16px;
                border-radius: 50px;
            }

            .hero-pill i {
                color: var(--teal);
                font-size: 0.70rem
            }

            .btn-primary {
                background: var(--teal);
                color: var(--white);
                padding: 14px 30px;
                border-radius: 50px;
                font-family: var(--font-body);
                font-size: 0.88rem;
                font-weight: 600;
                display: inline-flex;
                align-items: center;
                gap: 9px;
                transition: all var(--transition);
                border: none;
                cursor: pointer;
            }

            .btn-primary:hover {
                background: var(--teal-d);
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(26, 171, 152, 0.32);
                color: var(--white)
            }

            .btn-ghost {
                background: transparent;
                color: var(--white);
                padding: 13px 26px;
                border-radius: 50px;
                font-family: var(--font-body);
                font-size: 0.88rem;
                font-weight: 600;
                display: inline-flex;
                align-items: center;
                gap: 9px;
                border: 1.5px solid rgba(255, 255, 255, 0.28);
                transition: all var(--transition);
            }

            .btn-ghost:hover {
                background: rgba(255, 255, 255, 0.08);
                border-color: rgba(255, 255, 255, 0.58);
                color: var(--white)
            }

            .hero-btns {
                display: flex;
                gap: 14px;
                flex-wrap: wrap
            }

            /* Hero image stack */
            .clinic-hero-imgs {
                position: relative;
                align-self: flex-end;
                height: 420px
            }

            .hero-img-main {
                position: absolute;
                bottom: 0;
                right: 0;
                width: 83%;
                height: 436px;

                object-fit: cover;
                border-radius: var(--radius-lg) var(--radius-lg) 0 0;
                box-shadow: 0 -10px 60px rgba(0, 0, 0, 0.28);
            }

            .hero-img-thumb {
                position: absolute;
                bottom: 40px;
                left: 0;
                width: 46%;
                height: 200px;
                object-fit: cover;
                border-radius: var(--radius-lg);
                box-shadow: var(--shadow-lg);
                border: 4px solid var(--white);
            }

            .hero-badge-float {
                position: absolute;
                top: 11px;
                right: -12%;
                background: var(--white);
                border-radius: var(--radius);
                padding: 14px 18px;
                box-shadow: var(--shadow-lg);
                text-align: center;
                min-width: 120px;
            }

            .hero-badge-float-num {
                font-family: var(--font-head);
                font-size: 1.6rem;
                font-weight: 700;
                color: var(--teal);
                line-height: 1
            }

            .hero-badge-float-label {
                font-size: 0.64rem;
                color: var(--text-lt);
                margin-top: 4px;
                line-height: 1.4
            }

            /* ── TRUST STRIP ── */
            .trust-strip {
                background: var(--teal)
            }

            .trust-strip-inner {
                max-width: 1100px;
                margin: 0 auto;
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 0;
            }

            .trust-item {
                display: flex;
                align-items: center;
                gap: 14px;
                padding: 22px 28px;
                border-right: 1px solid rgba(255, 255, 255, 0.18);
            }

            .trust-item:last-child {
                border-right: none
            }

            .trust-icon {
                width: 40px;
                height: 40px;
                background: rgba(255, 255, 255, 0.15);
                border-radius: var(--radius-sm);
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0
            }

            .trust-icon i {
                color: var(--white);
                font-size: 0.95rem
            }

            .trust-text strong {
                display: block;
                font-size: 0.86rem;
                font-weight: 700;
                color: var(--white);
                margin-bottom: 2px
            }

            .trust-text span {
                font-size: 0.74rem;
                color: rgba(255, 255, 255, 0.68)
            }

            /* ── ABOUT CLINIC ── */
            .clinic-about {
                padding: 96px 5%;
                background: var(--white)
            }

            .clinic-about-grid {
                max-width: 1100px;
                margin: 0 auto;
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 80px;
                align-items: center
            }

            .clinic-about-text .section-label {
                color: var(--teal)
            }

            .clinic-about-text .section-label::before {
                background: var(--gold)
            }

            .clinic-about h2 {
                font-family: var(--font-head);
                font-size: clamp(1.8rem, 3vw, 2.4rem);
                color: var(--navy);
                font-weight: 600;
                line-height: 1.25;
                letter-spacing: -0.02em;
                margin-bottom: 18px
            }

            .clinic-about h2 em {
                color: var(--teal);
                font-style: italic
            }

            .clinic-about p {
                font-size: 0.95rem;
                color: var(--text-lt);
                line-height: 1.82;
                margin-bottom: 16px
            }

            .clinic-about p strong {
                color: var(--navy)
            }

            .clinic-highlights {
                display: flex;
                flex-direction: column;
                gap: 12px;
                margin-top: 28px
            }

            .clinic-hi {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 13px 16px;
                background: var(--off-white);
                border-radius: var(--radius-sm);
                border: 1px solid var(--border)
            }

            .clinic-hi i {
                color: var(--teal);
                flex-shrink: 0
            }

            .clinic-hi span {
                font-size: 0.87rem;
                color: var(--text)
            }

            /* About image mosaic */
            .clinic-about-imgs {
                position: relative;
                height: 500px
            }

            .about-img-a {
                position: absolute;
                top: 0;
                right: 0;
                width: 80%;
                height: 320px;
                object-fit: cover;
                border-radius: var(--radius-lg);
                box-shadow: var(--shadow-lg);
            }

            .about-img-b {
                position: absolute;
                bottom: 0;
                left: 0;
                width: 60%;
                height: 220px;
                object-fit: cover;
                border-radius: var(--radius-lg);
                box-shadow: var(--shadow-lg);
                border: 4px solid var(--white);
            }

            .about-img-accent {
                position: absolute;
                bottom: 20px;
                right: 0;
                width: 100px;
                height: 100px;
                background: var(--off-white);
                border-radius: var(--radius-lg);
                z-index: -1;
            }

            /* ── GALLERY ── */
            .clinic-gallery {
                padding: 96px 5%;
                background: var(--off-white)
            }

            .clinic-gallery-inner {
                max-width: 1100px;
                margin: 0 auto
            }

            .gallery-head {
                text-align: center;
                margin-bottom: 52px
            }

            .gallery-head h2 {
                font-family: var(--font-head);
                font-size: clamp(1.8rem, 3vw, 2.4rem);
                color: var(--navy);
                font-weight: 600;
                letter-spacing: -0.02em;
                margin-bottom: 12px
            }

            .gallery-head h2 em {
                color: var(--teal);
                font-style: italic
            }

            .gallery-head p {
                font-size: 0.95rem;
                color: var(--text-lt);
                max-width: 480px;
                margin: 0 auto;
                line-height: 1.72
            }

            .gallery-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                grid-template-rows: 240px 240px;
                gap: 16px;
            }

            .gallery-item {
                position: relative;
                overflow: hidden;
                border-radius: var(--radius-lg);
                cursor: pointer;
                box-shadow: var(--shadow-sm);
            }

            .gallery-item:first-child {
                grid-column: 1 / 2;
                grid-row: 1 / 3;
            }

            .gallery-item img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.5s ease;
                display: block;
            }

            .gallery-item:hover img {
                transform: scale(1.07)
            }

            .gallery-overlay {
                position: absolute;
                inset: 0;
                background: linear-gradient(to top, rgba(15, 26, 48, 0.60) 0%, transparent 55%);
                opacity: 0;
                transition: opacity var(--transition);
                display: flex;
                align-items: flex-end;
                padding: 20px;
            }

            .gallery-item:hover .gallery-overlay {
                opacity: 1
            }

            .gallery-overlay span {
                font-size: 0.82rem;
                font-weight: 600;
                color: var(--white)
            }

            .gallery-tag {
                position: absolute;
                top: 12px;
                left: 12px;
                background: rgba(255, 255, 255, 0.92);
                color: var(--navy);
                font-size: 0.64rem;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                padding: 4px 10px;
                border-radius: 50px;
                backdrop-filter: blur(4px);
            }

            /* ── LOCATION ── */
            .clinic-location {
                padding: 96px 5%;
                background: var(--white)
            }

            .clinic-location-inner {
                max-width: 1100px;
                margin: 0 auto
            }

            .location-head {
                text-align: center;
                margin-bottom: 52px
            }

            .location-head h2 {
                font-family: var(--font-head);
                font-size: clamp(1.8rem, 3vw, 2.4rem);
                color: var(--navy);
                font-weight: 600;
                letter-spacing: -0.02em;
                margin-bottom: 10px
            }

            .location-head h2 em {
                color: var(--teal);
                font-style: italic
            }

            .location-head p {
                font-size: 0.95rem;
                color: var(--text-lt);
                max-width: 480px;
                margin: 0 auto
            }

            .location-grid {
                display: grid;
                grid-template-columns: 1fr 360px;
                gap: 40px;
                align-items: start
            }

            .map-frame {
                width: 100%;
                height: 420px;
                border-radius: var(--radius-lg);
                overflow: hidden;
                border: 1.5px solid var(--border);
                box-shadow: var(--shadow)
            }

            .map-frame iframe {
                width: 100%;
                height: 100%;
                border: none;
                display: block
            }

            .location-details {
                display: flex;
                flex-direction: column;
                gap: 16px
            }

            .location-card {
                background: var(--off-white);
                border: 1.5px solid var(--border);
                border-radius: var(--radius-lg);
                padding: 24px 22px;
            }

            .location-card-title {
                font-family: var(--font-head);
                font-size: 0.95rem;
                color: var(--navy);
                font-weight: 700;
                margin-bottom: 16px;
                padding-bottom: 12px;
                border-bottom: 1px solid var(--border);
                position: relative
            }

            .location-card-title::after {
                content: '';
                position: absolute;
                bottom: -1px;
                left: 0;
                width: 28px;
                height: 2px;
                background: var(--gold)
            }

            .location-row {
                display: flex;
                align-items: flex-start;
                gap: 12px;
                padding: 10px 0;
                border-bottom: 1px solid var(--border)
            }

            .location-row:last-child {
                border-bottom: none;
                padding-bottom: 0
            }

            .loc-icon {
                width: 34px;
                height: 34px;
                background: var(--white);
                border: 1.5px solid var(--border);
                border-radius: var(--radius-sm);
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0
            }

            .loc-icon i {
                color: var(--teal);
                font-size: 0.82rem
            }

            .loc-detail strong {
                display: block;
                font-size: 0.80rem;
                font-weight: 700;
                color: var(--navy);
                margin-bottom: 2px
            }

            .loc-detail span {
                font-size: 0.80rem;
                color: var(--text-lt);
                line-height: 1.5
            }

            .metro-pill {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                background: rgba(26, 171, 152, 0.08);
                border: 1px solid rgba(26, 171, 152, 0.20);
                color: var(--teal-d);
                font-size: 0.74rem;
                font-weight: 600;
                padding: 4px 12px;
                border-radius: 50px;
                margin-top: 6px
            }

            .directions-btn {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 9px;
                background: var(--navy);
                color: var(--white);
                padding: 13px 20px;
                border-radius: 50px;
                font-size: 0.85rem;
                font-weight: 600;
                transition: all var(--transition);
                margin-top: 4px;
            }

            .directions-btn:hover {
                background: var(--teal);
                color: var(--white)
            }

            .directions-btn i {
                font-size: 0.80rem
            }

            /* OPD card */
            .opd-mini {
                background: linear-gradient(135deg, var(--navy-d) 0%, var(--navy) 100%);
                border-color: var(--navy)
            }

            .opd-mini .location-card-title {
                color: var(--white);
                border-bottom-color: rgba(255, 255, 255, 0.12)
            }

            .opd-row-item {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 10px 0;
                border-bottom: 1px solid rgba(255, 255, 255, 0.09)
            }

            .opd-row-item:last-child {
                border-bottom: none;
                padding-bottom: 0
            }

            .opd-day-label {
                font-size: 0.82rem;
                color: rgba(255, 255, 255, 0.55)
            }

            .opd-time-val {
                font-size: 0.82rem;
                font-weight: 700;
                color: var(--white)
            }

            .opd-time-val.closed {
                color: rgba(255, 255, 255, 0.28);
                font-weight: 400
            }

            .opd-note {
                margin-top: 14px;
                background: rgba(26, 171, 152, 0.14);
                border: 1px solid rgba(26, 171, 152, 0.28);
                border-radius: var(--radius-sm);
                padding: 10px 14px;
                font-size: 0.78rem;
                color: rgba(255, 255, 255, 0.68);
                display: flex;
                align-items: flex-start;
                gap: 8px;
                line-height: 1.60
            }

            .opd-note i {
                color: var(--teal);
                flex-shrink: 0;
                margin-top: 2px
            }

            /* ── AFFILIATIONS ── */
            .clinic-affiliations {
                padding: 80px 5%;
                background: var(--off-white);
                border-top: 1px solid var(--border)
            }

            .clinic-affiliations-inner {
                max-width: 1100px;
                margin: 0 auto
            }

            .aff-head {
                text-align: center;
                margin-bottom: 48px
            }

            .aff-head h2 {
                font-family: var(--font-head);
                font-size: clamp(1.6rem, 2.8vw, 2.2rem);
                color: var(--navy);
                font-weight: 600;
                letter-spacing: -0.02em;
                margin-bottom: 10px
            }

            .aff-head h2 em {
                color: var(--teal);
                font-style: italic
            }

            .aff-head p {
                font-size: 0.92rem;
                color: var(--text-lt)
            }

            .aff-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 18px
            }

            .aff-card {
                background: var(--white);
                border: 1.5px solid var(--border);
                border-radius: var(--radius-lg);
                padding: 26px 22px;
                display: flex;
                align-items: flex-start;
                gap: 16px;
                transition: all var(--transition);
                position: relative;
                overflow: hidden;
            }

            .aff-card::before {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: linear-gradient(90deg, var(--teal), var(--gold));
                transform: scaleX(0);
                transition: transform var(--transition)
            }

            .aff-card:hover {
                box-shadow: var(--shadow);
                transform: translateY(-4px);
                border-color: var(--teal)
            }

            .aff-card:hover::before {
                transform: scaleX(1)
            }

            .aff-icon {
                width: 48px;
                height: 48px;
                background: rgba(26, 171, 152, 0.08);
                border-radius: var(--radius-sm);
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
                border: 1px solid rgba(26, 171, 152, 0.16)
            }

            .aff-icon i {
                color: var(--teal);
                font-size: 1rem
            }

            .aff-card h4 {
                font-family: var(--font-head);
                font-size: 0.96rem;
                color: var(--navy);
                font-weight: 700;
                margin-bottom: 4px
            }

            .aff-card p {
                font-size: 0.80rem;
                color: var(--text-lt);
                line-height: 1.60
            }

            .aff-badge {
                display: inline-block;
                font-size: 0.64rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                color: var(--teal-d);
                background: rgba(26, 171, 152, 0.08);
                border: 1px solid rgba(26, 171, 152, 0.18);
                padding: 3px 9px;
                border-radius: 50px;
                margin-top: 6px
            }

            /* ── CTA ── */
            .clinic-cta {
                background: linear-gradient(135deg, var(--navy-d) 0%, var(--navy) 100%);
                padding: 80px 5%;
                text-align: center;
                position: relative;
                overflow: hidden
            }

            .clinic-cta::before {
                content: '';
                position: absolute;
                inset: 0;
                background: repeating-linear-gradient(-55deg, transparent 0px, transparent 18px, rgba(255, 255, 255, 0.015) 18px, rgba(255, 255, 255, 0.015) 20px)
            }

            .clinic-cta-inner {
                position: relative;
                z-index: 1
            }

            .clinic-cta h2 {
                font-family: var(--font-head);
                font-size: clamp(1.8rem, 3vw, 2.6rem);
                color: var(--white);
                margin-bottom: 14px;
                font-weight: 600
            }

