              <img src="/images/Joint Trauma.jpg" alt="Disc treatment herniated disc spine" loading="lazy">
              <div class="service-card-img-overlay"></div>
              <span class="service-tag">Spine</span>
            </div>
            <div class="service-body">
              <div class="service-icon-wrap"><i class="fa-solid fa-layer-group"></i></div>
