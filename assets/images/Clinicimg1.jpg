@keyframes paginate-forward {=20
  0% { transform: translateX(0px); }
  100% { transform: translateX(-50%); }
}

@keyframes paginate-backward {=20
  0% { transform: translateX(-50%); }
  100% { transform: translateX(0px); }
}

@keyframes paused-forward {=20
  0% { transform: translateX(0px); }
  100% { transform: translateX(0px); }
}

@keyframes paused-backward {=20
  0% { transform: translateX(-50%); }
  100% { transform: translateX(-50%); }
}

